---
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);
---

<section id="showcase" class="py-20 lg:py-32 bg-background-secondary relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Showcase Block 1 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-32">
      <!-- Content -->
      <div class="order-2 lg:order-1">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-6">
          {t.showcase.block1Title1}
          <span class="bg-gradient-primary bg-clip-text text-transparent">{t.showcase.block1TitleHighlight}</span>
        </h2>
        <p class="text-xl text-text-secondary mb-8 leading-relaxed">
          {t.showcase.block1Text}
        </p>
        
        <!-- Supporting Points -->
        <div class="space-y-4 mb-8">
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 bg-primary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <p class="text-text-secondary">{t.showcase.block1Point1}</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 bg-primary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <p class="text-text-secondary">{t.showcase.block1Point2}</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 bg-primary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <p class="text-text-secondary">{t.showcase.block1Point3}</p>
          </div>
        </div>
        
        <button class="bg-primary-main hover:bg-primary-dark text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg hover:shadow-primary-main/30">
          {t.showcase.block1Cta}
        </button>
      </div>
      
      <!-- Mockup -->
      <div class="order-1 lg:order-2 relative">
        <div class="bg-background-primary/90 backdrop-blur-xl border border-border-primary rounded-2xl p-6 shadow-2xl transform hover:scale-105 transition-transform duration-500">
          <!-- Workflow Builder Interface -->
          <div class="space-y-4">
            <!-- Header -->
            <div class="flex items-center justify-between pb-4 border-b border-border-primary">
              <h3 class="text-text-primary font-semibold">{t.showcase.mockup1Title}</h3>
              <div class="flex space-x-2">
                <div class="w-2 h-2 bg-red-500 rounded-full"></div>
                <div class="w-2 h-2 bg-yellow-500 rounded-full"></div>
                <div class="w-2 h-2 bg-secondary-main rounded-full"></div>
              </div>
            </div>
            
            <!-- Workflow Steps -->
            <div class="flex flex-col space-y-4">
              <div class="flex items-center space-x-4">
                <div class="w-8 h-8 bg-primary-main rounded-lg flex items-center justify-center">
                  <span class="text-white text-xs font-bold">1</span>
                </div>
                <div class="flex-1 bg-background-secondary rounded-lg p-3">
                  <div class="h-2 bg-text-muted/20 rounded mb-2"></div>
                  <div class="h-1 bg-text-muted/10 rounded w-2/3"></div>
                </div>
              </div>
              
              <div class="flex justify-center">
                <div class="w-0.5 h-8 bg-border-primary"></div>
              </div>
              
              <div class="flex items-center space-x-4">
                <div class="w-8 h-8 bg-secondary-main rounded-lg flex items-center justify-center">
                  <span class="text-white text-xs font-bold">2</span>
                </div>
                <div class="flex-1 bg-background-secondary rounded-lg p-3">
                  <div class="h-2 bg-text-muted/20 rounded mb-2"></div>
                  <div class="h-1 bg-text-muted/10 rounded w-3/4"></div>
                </div>
              </div>
              
              <div class="flex justify-center">
                <div class="w-0.5 h-8 bg-border-primary"></div>
              </div>
              
              <div class="flex items-center space-x-4">
                <div class="w-8 h-8 bg-gradient-accent rounded-lg flex items-center justify-center">
                  <span class="text-white text-xs font-bold">3</span>
                </div>
                <div class="flex-1 bg-background-secondary rounded-lg p-3">
                  <div class="h-2 bg-text-muted/20 rounded mb-2"></div>
                  <div class="h-1 bg-text-muted/10 rounded w-1/2"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Floating Status -->
        <div class="absolute -top-4 -right-4 bg-secondary-main/20 backdrop-blur-sm border border-secondary-main/30 rounded-lg p-3 animate-pulse">
          <div class="flex items-center space-x-2">
            <div class="w-2 h-2 bg-secondary-main rounded-full"></div>
            <span class="text-xs text-secondary-main font-medium">{t.showcase.mockup1Status}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Showcase Block 2 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-32">
      <!-- Mockup -->
      <div class="relative">
        <div class="bg-background-primary/90 backdrop-blur-xl border border-border-primary rounded-2xl p-6 shadow-2xl transform hover:scale-105 transition-transform duration-500">
          <!-- Analytics Dashboard -->
          <div class="space-y-4">
            <!-- Header -->
            <div class="flex items-center justify-between pb-4 border-b border-border-primary">
              <h3 class="text-text-primary font-semibold">{t.showcase.mockup2Title}</h3>
              <div class="flex items-center space-x-2">
                <div class="w-2 h-2 bg-secondary-main rounded-full animate-pulse"></div>
                <span class="text-xs text-text-muted">{t.showcase.mockup2Status}</span>
              </div>
            </div>
            
            <!-- Stats Grid -->
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-background-secondary rounded-lg p-4">
                <div class="text-2xl font-bold text-primary-main mb-1">98.7%</div>
                <div class="text-xs text-text-muted">{t.showcase.mockup2Stat1}</div>
              </div>
              <div class="bg-background-secondary rounded-lg p-4">
                <div class="text-2xl font-bold text-secondary-main mb-1">2.3x</div>
                <div class="text-xs text-text-muted">{t.showcase.mockup2Stat2}</div>
              </div>
            </div>
            
            <!-- Chart Visualization -->
            <div class="bg-background-secondary rounded-lg p-4">
              <div class="flex items-end justify-between h-20 space-x-2">
                <div class="bg-primary-main/30 w-4 h-8 rounded-sm"></div>
                <div class="bg-primary-main/50 w-4 h-12 rounded-sm"></div>
                <div class="bg-primary-main/70 w-4 h-16 rounded-sm"></div>
                <div class="bg-primary-main w-4 h-20 rounded-sm"></div>
                <div class="bg-primary-main/80 w-4 h-14 rounded-sm"></div>
                <div class="bg-primary-main/60 w-4 h-10 rounded-sm"></div>
                <div class="bg-primary-main/90 w-4 h-18 rounded-sm"></div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Floating Metrics -->
        <div class="absolute -bottom-4 -left-4 bg-primary-main/20 backdrop-blur-sm border border-primary-main/30 rounded-lg p-3 animate-float">
          <div class="text-primary-main font-semibold text-sm">{t.showcase.mockup2Growth}</div>
        </div>
      </div>
      
      <!-- Content -->
      <div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-6">
          {t.showcase.block2Title1}
          <span class="bg-gradient-accent bg-clip-text text-transparent">{t.showcase.block2TitleHighlight}</span>
        </h2>
        <p class="text-xl text-text-secondary mb-8 leading-relaxed">
          {t.showcase.block2Text}
        </p>
        
        <!-- Supporting Points -->
        <div class="space-y-4 mb-8">
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <p class="text-text-secondary">{t.showcase.block2Point1}</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <p class="text-text-secondary">{t.showcase.block2Point2}</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <p class="text-text-secondary">{t.showcase.block2Point3}</p>
          </div>
        </div>
        
        <button class="border border-border-primary hover:border-border-accent bg-background-glassmorphism backdrop-blur-sm text-text-primary px-6 py-3 rounded-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:bg-background-secondary/50">
          {t.showcase.block2Cta}
        </button>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-6">
        {t.showcase.bottomTitle}
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-8">
        {t.showcase.bottomText}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="bg-primary-main hover:bg-primary-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-main/30">
          {t.showcase.bottomCta1}
        </button>
        <button class="border border-border-primary hover:border-border-accent bg-background-glassmorphism backdrop-blur-sm text-text-primary px-8 py-4 rounded-xl text-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:bg-background-secondary/50">
          {t.showcase.bottomCta2}
        </button>
      </div>
    </div>
  </div>

  <!-- Background Elements -->
  <div class="absolute top-1/4 left-0 w-1/3 h-96 bg-gradient-mesh opacity-20 pointer-events-none blur-3xl"></div>
  <div class="absolute bottom-1/4 right-0 w-1/3 h-96 bg-primary-main/10 rounded-full blur-3xl pointer-events-none"></div>
</section> 