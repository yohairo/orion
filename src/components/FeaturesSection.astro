---
// Features Section component
---

<section id="features" class="py-20 lg:py-32 bg-background-primary relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-6">
        Powerful Features for
        <span class="bg-gradient-primary bg-clip-text text-transparent">Modern Teams</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed">
        Everything you need to scale your business, automate workflows, and drive growth with cutting-edge technology.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Feature 1: Automation -->
      <div class="group bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-12 h-12 bg-gradient-primary rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Smart Automation</h3>
          <p class="text-text-secondary leading-relaxed">
            Automate repetitive tasks and workflows with AI-powered intelligence. Save hours of manual work while ensuring accuracy and consistency.
          </p>
        </div>
        <div class="flex items-center text-primary-main text-sm font-medium group-hover:text-primary-light transition-colors duration-300">
          Learn more
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </div>

      <!-- Feature 2: Analytics -->
      <div class="group bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-12 h-12 bg-gradient-accent rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Real-time Analytics</h3>
          <p class="text-text-secondary leading-relaxed">
            Get instant insights into your business performance with comprehensive dashboards and real-time reporting capabilities.
          </p>
        </div>
        <div class="flex items-center text-primary-main text-sm font-medium group-hover:text-primary-light transition-colors duration-300">
          Learn more
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </div>

      <!-- Feature 3: Scalability -->
      <div class="group bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-12 h-12 bg-secondary-main/80 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Infinite Scale</h3>
          <p class="text-text-secondary leading-relaxed">
            Built for growth. Scale from startup to enterprise with cloud-native architecture that grows with your business needs.
          </p>
        </div>
        <div class="flex items-center text-primary-main text-sm font-medium group-hover:text-primary-light transition-colors duration-300">
          Learn more
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </div>

      <!-- Feature 4: Security -->
      <div class="group bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-12 h-12 bg-gradient-primary rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Enterprise Security</h3>
          <p class="text-text-secondary leading-relaxed">
            Bank-grade security with end-to-end encryption, SSO integration, and compliance with industry standards like SOC 2 and GDPR.
          </p>
        </div>
        <div class="flex items-center text-primary-main text-sm font-medium group-hover:text-primary-light transition-colors duration-300">
          Learn more
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </div>

      <!-- Feature 5: Integration -->
      <div class="group bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-12 h-12 bg-gradient-accent rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a1 1 0 01-1-1V9a1 1 0 011-1h1a2 2 0 100-4H4a1 1 0 01-1-1V4a1 1 0 011-1h3a1 1 0 011 1v1z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Seamless Integrations</h3>
          <p class="text-text-secondary leading-relaxed">
            Connect with 500+ apps and services. From CRM to accounting, integrate all your tools in one unified platform.
          </p>
        </div>
        <div class="flex items-center text-primary-main text-sm font-medium group-hover:text-primary-light transition-colors duration-300">
          Learn more
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </div>

      <!-- Feature 6: Support -->
      <div class="group bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-12 h-12 bg-secondary-main/80 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">24/7 Expert Support</h3>
          <p class="text-text-secondary leading-relaxed">
            Get help when you need it with round-the-clock support from our expert team. Live chat, phone, and dedicated account managers.
          </p>
        </div>
        <div class="flex items-center text-primary-main text-sm font-medium group-hover:text-primary-light transition-colors duration-300">
          Learn more
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <p class="text-text-secondary mb-6">Ready to experience the difference?</p>
      <button class="bg-primary-main hover:bg-primary-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-main/30">
        Start Your Free Trial
      </button>
    </div>
  </div>

  <!-- Background Elements -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-radial opacity-30 pointer-events-none"></div>
</section> 