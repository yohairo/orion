---
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);
---

<section id="contact" class="py-20 lg:py-32 bg-background-secondary relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    
    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-4 sm:mb-6 px-2 break-words">
        {t.contact.headline1}
        <span class="bg-gradient-primary bg-clip-text">{t.contact.headlineHighlight}</span>
      </h2>
      <p class="text-lg sm:text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed px-2 break-words">
        {t.contact.description}
      </p>
    </div>

    <!-- Contact Options Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 mb-12 sm:mb-16 w-full">
      
      <!-- Quick Contact Form -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 sm:p-8 w-full">
        <div class="mb-4 sm:mb-6">
          <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-2 sm:mb-3 break-words">{t.contact.formTitle}</h3>
          <p class="text-text-secondary text-sm sm:text-base break-words">{t.contact.formText}</p>
        </div>
        
        <form class="space-y-4 sm:space-y-6 w-full" id="contact-form">
          <!-- Name and Email Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 w-full">
            <div class="w-full">
              <label for="name" class="block text-sm font-medium text-text-primary mb-2 break-words">{t.contact.nameLabel}</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted text-sm sm:text-base"
                placeholder={t.contact.namePlaceholder}
              />
            </div>
            <div class="w-full">
              <label for="email" class="block text-sm font-medium text-text-primary mb-2 break-words">{t.contact.emailLabel}</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted text-sm sm:text-base"
                placeholder={t.contact.emailPlaceholder}
              />
            </div>
          </div>

          <!-- Company and Role Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 w-full">
            <div class="w-full">
              <label for="company" class="block text-sm font-medium text-text-primary mb-2 break-words">{t.contact.companyLabel}</label>
              <input 
                type="text" 
                id="company" 
                name="company" 
                required
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted text-sm sm:text-base"
                placeholder={t.contact.companyPlaceholder}
              />
            </div>
            <div class="w-full">
              <label for="role" class="block text-sm font-medium text-text-primary mb-2 break-words">{t.contact.roleLabel}</label>
              <select 
                id="role" 
                name="role"
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary text-sm sm:text-base"
              >
                <option value="">{t.contact.rolePlaceholder}</option>
                <option value="ceo">{t.contact.roleCeo}</option>
                <option value="cto">{t.contact.roleCto}</option>
                <option value="operations">{t.contact.roleOps}</option>
                <option value="it">{t.contact.roleIt}</option>
                <option value="other">{t.contact.roleOther}</option>
              </select>
            </div>
          </div>

          <!-- Inquiry Type -->
          <div class="w-full">
            <label for="inquiry" class="block text-sm font-medium text-text-primary mb-2 break-words">{t.contact.inquiryLabel}</label>
            <select 
              id="inquiry" 
              name="inquiry"
              required
              class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary text-sm sm:text-base"
            >
              <option value="">{t.contact.inquiryPlaceholder}</option>
              <option value="automation">{t.contact.inquiryAutomation}</option>
              <option value="integration">{t.contact.inquiryIntegration}</option>
              <option value="analytics">{t.contact.inquiryAnalytics}</option>
              <option value="custom">{t.contact.inquiryCustom}</option>
              <option value="demo">{t.contact.inquiryDemo}</option>
              <option value="pricing">{t.contact.inquiryPricing}</option>
            </select>
          </div>

          <!-- Message -->
          <div class="w-full">
            <label for="message" class="block text-sm font-medium text-text-primary mb-2 break-words">{t.contact.messageLabel}</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4"
              class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted resize-none text-sm sm:text-base"
              placeholder={t.contact.messagePlaceholder}
            ></textarea>
          </div>

          <!-- Budget Range -->
          <div class="w-full">
            <label for="budget" class="block text-sm font-medium text-text-primary mb-2 break-words">{t.contact.budgetLabel}</label>
            <select 
              id="budget" 
              name="budget"
              class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary text-sm sm:text-base"
            >
              <option value="">{t.contact.budgetPlaceholder}</option>
              <option value="10k-25k">{t.contact.budget1}</option>
              <option value="25k-50k">{t.contact.budget2}</option>
              <option value="50k-100k">{t.contact.budget3}</option>
              <option value="100k+">{t.contact.budget4}</option>
              <option value="discuss">{t.contact.budgetDiscuss}</option>
            </select>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="w-full bg-primary-main hover:bg-primary-dark text-white py-3 sm:py-4 rounded-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-main/30 text-sm sm:text-base break-words"
          >
            {t.contact.submitCta}
          </button>

          <!-- Response Time -->
          <div class="text-center">
            <div class="flex items-center justify-center space-x-2 text-secondary-main">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-xs sm:text-sm font-medium whitespace-nowrap">{t.contact.responseTime}</span>
            </div>
          </div>
        </form>
      </div>

      <!-- Calendar Booking -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 sm:p-8 w-full">
        <div class="mb-4 sm:mb-6">
          <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-2 sm:mb-3 break-words">{t.contact.calendarTitle}</h3>
          <p class="text-text-secondary text-sm sm:text-base break-words">{t.contact.calendarText}</p>
        </div>

        <!-- Call Benefits -->
        <div class="space-y-3 sm:space-y-4 mb-6 sm:mb-8">
          <div class="flex items-start space-x-3">
            <div class="w-5 sm:w-6 h-5 sm:h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-2.5 sm:w-3 h-2.5 sm:h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h4 class="font-semibold text-text-primary text-sm sm:text-base break-words">{t.contact.benefit1Title}</h4>
              <p class="text-text-secondary text-xs sm:text-sm break-words">{t.contact.benefit1Text}</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-5 sm:w-6 h-5 sm:h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-2.5 sm:w-3 h-2.5 sm:h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h4 class="font-semibold text-text-primary text-sm sm:text-base break-words">{t.contact.benefit2Title}</h4>
              <p class="text-text-secondary text-xs sm:text-sm break-words">{t.contact.benefit2Text}</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-5 sm:w-6 h-5 sm:h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-2.5 sm:w-3 h-2.5 sm:h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h4 class="font-semibold text-text-primary text-sm sm:text-base break-words">{t.contact.benefit3Title}</h4>
              <p class="text-text-secondary text-xs sm:text-sm break-words">{t.contact.benefit3Text}</p>
            </div>
          </div>
        </div>

        <!-- Calendar Embed Placeholder -->
        <div class="bg-background-secondary rounded-lg p-4 sm:p-6 text-center border-2 border-dashed border-border-primary w-full">
          <div class="mb-4">
            <div class="w-12 h-12 bg-secondary-main/20 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-secondary-main" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h4 class="font-semibold text-text-primary mb-2 text-sm sm:text-base break-words">{t.contact.calendarIntegration}</h4>
            <p class="text-text-secondary text-xs sm:text-sm mb-4 break-words">{t.contact.calendarIntegrationText}</p>
            <button class="bg-secondary-main hover:bg-secondary-dark text-white px-4 sm:px-6 py-2 sm:py-3 rounded-lg font-semibold transition-all duration-300 text-sm sm:text-base w-full sm:w-auto break-words">
              {t.contact.calendarCta}
            </button>
          </div>
        </div>
      </div>
    </div>



  </div>

  <!-- Background Effects -->
  <div class="absolute top-0 left-0 w-1/3 h-1/2 bg-gradient-radial opacity-20 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-1/4 h-1/3 bg-gradient-mesh opacity-10 pointer-events-none"></div>
</section>

<script>
  // Form submission handler
  document.getElementById('contact-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const form = e.target as HTMLFormElement;
    
    // Get form data
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // Simple validation
    if (!data.name || !data.email || !data.company || !data.inquiry) {
      alert('Please fill in all required fields.');
      return;
    }
    
    // Show success message (replace with actual form submission)
    alert('Thank you! We\'ll respond within 2 hours.');
    form.reset();
  });
</script> 