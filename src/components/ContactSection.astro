---
// Contact Section component with forms and scheduling
---

<section id="contact" class="py-20 lg:py-32 bg-background-secondary relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    
    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-4 sm:mb-6 px-2 break-words">
        Let's Transform Your Business
        <span class="bg-gradient-primary bg-clip-text text-transparent">Together</span>
      </h2>
      <p class="text-lg sm:text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed px-2 break-words">
        Ready to see real results? Choose how you'd like to connect with our team.
      </p>
    </div>

    <!-- Contact Options Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 mb-12 sm:mb-16 w-full">
      
      <!-- Quick Contact Form -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 sm:p-8 w-full">
        <div class="mb-4 sm:mb-6">
          <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-2 sm:mb-3 break-words">Get Started Now</h3>
          <p class="text-text-secondary text-sm sm:text-base break-words">Tell us about your project and we'll respond within 2 hours.</p>
        </div>
        
        <form class="space-y-4 sm:space-y-6 w-full" id="contact-form">
          <!-- Name and Email Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 w-full">
            <div class="w-full">
              <label for="name" class="block text-sm font-medium text-text-primary mb-2 break-words">Full Name *</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted text-sm sm:text-base"
                placeholder="John Smith"
              />
            </div>
            <div class="w-full">
              <label for="email" class="block text-sm font-medium text-text-primary mb-2 break-words">Work Email *</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted text-sm sm:text-base"
                placeholder="john@company.com"
              />
            </div>
          </div>

          <!-- Company and Role Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 w-full">
            <div class="w-full">
              <label for="company" class="block text-sm font-medium text-text-primary mb-2 break-words">Company *</label>
              <input 
                type="text" 
                id="company" 
                name="company" 
                required
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted text-sm sm:text-base"
                placeholder="Acme Corp"
              />
            </div>
            <div class="w-full">
              <label for="role" class="block text-sm font-medium text-text-primary mb-2 break-words">Your Role</label>
              <select 
                id="role" 
                name="role"
                class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary text-sm sm:text-base"
              >
                <option value="">Select Role</option>
                <option value="ceo">CEO/Founder</option>
                <option value="cto">CTO</option>
                <option value="operations">Operations Manager</option>
                <option value="it">IT Director</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>

          <!-- Inquiry Type -->
          <div class="w-full">
            <label for="inquiry" class="block text-sm font-medium text-text-primary mb-2 break-words">What can we help with? *</label>
            <select 
              id="inquiry" 
              name="inquiry"
              required
              class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary text-sm sm:text-base"
            >
              <option value="">Select Inquiry Type</option>
              <option value="automation">Process Automation</option>
              <option value="integration">System Integration</option>
              <option value="analytics">Analytics & Reporting</option>
              <option value="custom">Custom Solution</option>
              <option value="demo">Product Demo</option>
              <option value="pricing">Pricing Information</option>
            </select>
          </div>

          <!-- Message -->
          <div class="w-full">
            <label for="message" class="block text-sm font-medium text-text-primary mb-2 break-words">Project Details</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4"
              class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary placeholder-text-muted resize-none text-sm sm:text-base"
              placeholder="Tell us about your current challenges and what you're hoping to achieve..."
            ></textarea>
          </div>

          <!-- Budget Range -->
          <div class="w-full">
            <label for="budget" class="block text-sm font-medium text-text-primary mb-2 break-words">Project Budget Range</label>
            <select 
              id="budget" 
              name="budget"
              class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-background-secondary border border-border-primary rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-main focus:border-transparent text-text-primary text-sm sm:text-base"
            >
              <option value="">Select Budget Range</option>
              <option value="10k-25k">$10K - $25K</option>
              <option value="25k-50k">$25K - $50K</option>
              <option value="50k-100k">$50K - $100K</option>
              <option value="100k+">$100K+</option>
              <option value="discuss">Let's Discuss</option>
            </select>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="w-full bg-primary-main hover:bg-primary-dark text-white py-3 sm:py-4 rounded-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-main/30 text-sm sm:text-base break-words"
          >
            Send Message
          </button>

          <!-- Response Time -->
          <div class="text-center">
            <div class="flex items-center justify-center space-x-2 text-secondary-main">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-xs sm:text-sm font-medium whitespace-nowrap">We'll respond within 2 hours</span>
            </div>
          </div>
        </form>
      </div>

      <!-- Calendar Booking -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 sm:p-8 w-full">
        <div class="mb-4 sm:mb-6">
          <h3 class="text-xl sm:text-2xl font-bold text-text-primary mb-2 sm:mb-3 break-words">Book a Strategy Call</h3>
          <p class="text-text-secondary text-sm sm:text-base break-words">Schedule a 30-minute call to discuss your specific needs and get a custom solution proposal.</p>
        </div>

        <!-- Call Benefits -->
        <div class="space-y-3 sm:space-y-4 mb-6 sm:mb-8">
          <div class="flex items-start space-x-3">
            <div class="w-5 sm:w-6 h-5 sm:h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-2.5 sm:w-3 h-2.5 sm:h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h4 class="font-semibold text-text-primary text-sm sm:text-base break-words">Custom ROI Analysis</h4>
              <p class="text-text-secondary text-xs sm:text-sm break-words">Get a detailed breakdown of potential savings and revenue impact for your specific use case.</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-5 sm:w-6 h-5 sm:h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-2.5 sm:w-3 h-2.5 sm:h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h4 class="font-semibold text-text-primary text-sm sm:text-base break-words">Technical Assessment</h4>
              <p class="text-text-secondary text-xs sm:text-sm break-words">Review your current systems and identify the best integration approach.</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <div class="w-5 sm:w-6 h-5 sm:h-6 bg-secondary-main rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-2.5 sm:w-3 h-2.5 sm:h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <h4 class="font-semibold text-text-primary text-sm sm:text-base break-words">Implementation Roadmap</h4>
              <p class="text-text-secondary text-xs sm:text-sm break-words">Get a clear timeline and next steps for your automation project.</p>
            </div>
          </div>
        </div>

        <!-- Calendar Embed Placeholder -->
        <div class="bg-background-secondary rounded-lg p-4 sm:p-6 text-center border-2 border-dashed border-border-primary w-full">
          <div class="mb-4">
            <div class="w-12 h-12 bg-secondary-main/20 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-secondary-main" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h4 class="font-semibold text-text-primary mb-2 text-sm sm:text-base break-words">Calendar Integration</h4>
            <p class="text-text-secondary text-xs sm:text-sm mb-4 break-words">Book directly through our scheduling system</p>
            <button class="bg-secondary-main hover:bg-secondary-dark text-white px-4 sm:px-6 py-2 sm:py-3 rounded-lg font-semibold transition-all duration-300 text-sm sm:text-base w-full sm:w-auto break-words">
              Schedule 30-Min Call
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Alternative Contact Methods -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      
      <!-- Direct Email -->
      <div class="text-center bg-background-card/50 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
        <div class="w-12 h-12 bg-gradient-primary rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-2">Email Us</h3>
        <p class="text-text-secondary text-sm mb-3">For detailed inquiries and project discussions</p>
        <a href="mailto:hello@orion.ai" class="text-primary-main hover:text-primary-light font-medium transition-colors">
          hello@orion.ai
        </a>
      </div>

      <!-- Phone -->
      <div class="text-center bg-background-card/50 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
        <div class="w-12 h-12 bg-gradient-accent rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-2">Call Us</h3>
        <p class="text-text-secondary text-sm mb-3">Speak directly with our solutions team</p>
        <a href="tel:+1-555-0123" class="text-primary-main hover:text-primary-light font-medium transition-colors">
          +1 (555) 012-3456
        </a>
        <div class="text-xs text-text-muted mt-1">Mon-Fri 9AM-6PM EST</div>
      </div>

      <!-- Live Chat -->
      <div class="text-center bg-background-card/50 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
        <div class="w-12 h-12 bg-secondary-main rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-2">Live Chat</h3>
        <p class="text-text-secondary text-sm mb-3">Get instant answers to your questions</p>
        <button class="text-primary-main hover:text-primary-light font-medium transition-colors">
          Start Chat
        </button>
        <div class="text-xs text-text-muted mt-1">Usually responds in 5 minutes</div>
      </div>

    </div>

    <!-- Trust Indicators -->
    <div class="text-center">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="flex items-center justify-center space-x-3">
          <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <span class="text-text-secondary font-medium">SOC 2 Compliant</span>
        </div>
        <div class="flex items-center justify-center space-x-3">
          <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <span class="text-text-secondary font-medium">GDPR Compliant</span>
        </div>
        <div class="flex items-center justify-center space-x-3">
          <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <span class="text-text-secondary font-medium">Enterprise Security</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Background Effects -->
  <div class="absolute top-0 left-0 w-1/3 h-1/2 bg-gradient-radial opacity-20 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-1/4 h-1/3 bg-gradient-mesh opacity-10 pointer-events-none"></div>
</section>

<script>
  // Form submission handler
  document.getElementById('contact-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const form = e.target as HTMLFormElement;
    
    // Get form data
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // Simple validation
    if (!data.name || !data.email || !data.company || !data.inquiry) {
      alert('Please fill in all required fields.');
      return;
    }
    
    // Show success message (replace with actual form submission)
    alert('Thank you! We\'ll respond within 2 hours.');
    form.reset();
  });
</script> 