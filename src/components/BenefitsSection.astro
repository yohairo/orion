---
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);
---

<style>
  /* Background Styles */
  .benefits-bg {
    background: linear-gradient(135deg, #1e2124 0%, #2a2d32 25%, #232528 50%, #1a1d21 75%, #1e2124 100%);
    position: relative;
  }
  
  .benefits-bg::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 30%, rgba(255, 164, 0, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 70%, rgba(234, 246, 255, 0.06) 0%, transparent 50%);
    pointer-events: none;
  }
  
  /* Floating Elements */
  .benefit-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(30px);
    opacity: 0.3;
    animation: benefit-float 25s ease-in-out infinite;
  }
  
  .benefit-orb-1 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(255, 164, 0, 0.1) 0%, transparent 70%);
    top: 20%;
    left: -5%;
    animation-delay: 0s;
  }
  
  .benefit-orb-2 {
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(234, 246, 255, 0.08) 0%, transparent 70%);
    top: 60%;
    right: -3%;
    animation-delay: -12s;
  }
  
  @keyframes benefit-float {
    0%, 100% {
      transform: translateY(0px) translateX(0px) scale(1);
    }
    33% {
      transform: translateY(-15px) translateX(8px) scale(1.05);
    }
    66% {
      transform: translateY(-8px) translateX(-12px) scale(0.95);
    }
  }
  
  /* Enhanced Cards */
  .benefit-card {
    background: linear-gradient(145deg, rgba(55, 65, 81, 0.4), rgba(75, 85, 99, 0.2));
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .benefit-card:hover {
    background: linear-gradient(145deg, rgba(55, 65, 81, 0.6), rgba(75, 85, 99, 0.3));
    border-color: rgba(255, 164, 0, 0.3);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(255, 164, 0, 0.1);
  }
  
  /* Liquid Glass CTA */
  .liquid-cta-btn {
    background: rgba(255, 164, 0, 0.15);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 164, 0, 0.3);
    box-shadow: 0 8px 32px rgba(255, 164, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
  }
  
  .liquid-cta-btn:hover {
    transform: scale(1.05) translateY(-2px);
    box-shadow: 0 12px 40px rgba(255, 164, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  
  /* Stars */
  .benefit-star {
    position: absolute;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 50%;
    animation: benefit-twinkle 4s ease-in-out infinite;
  }
  
  .benefit-star-small { width: 1px; height: 1px; }
  .benefit-star-medium { width: 2px; height: 2px; }
  
  @keyframes benefit-twinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }
</style>

 <section id="benefits" class="benefits-bg py-20 lg:py-32 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="benefit-orb benefit-orb-1"></div>
  <div class="benefit-orb benefit-orb-2"></div>
  
  <!-- Stars -->
  <div class="benefit-star benefit-star-small" style="top: 15%; left: 10%; animation-delay: 0s;"></div>
  <div class="benefit-star benefit-star-medium" style="top: 25%; left: 85%; animation-delay: -1s;"></div>
  <div class="benefit-star benefit-star-small" style="top: 65%; left: 15%; animation-delay: -2s;"></div>
  <div class="benefit-star benefit-star-medium" style="top: 75%; left: 90%; animation-delay: -3s;"></div>
  <div class="benefit-star benefit-star-small" style="top: 35%; left: 75%; animation-delay: -1.5s;"></div>
  <div class="benefit-star benefit-star-small" style="top: 85%; left: 40%; animation-delay: -2.5s;"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 sm:mb-6 px-2 break-words">
        {t.benefits.headline1}
        <div class="relative inline-block">
          <span class="text-white font-bold relative">
            {t.benefits.headlineHighlight}
            <div 
              class="absolute bottom-[6px] left-0 w-full h-[0.15em] bg-primary-400 transform origin-left"
              style="animation: scaleX 0.4s ease-out 1.4s forwards;"
            ></div>
          </span>
        </div>
      </h2>
      <p class="text-base sm:text-lg text-gray-400 max-w-3xl mx-auto leading-relaxed px-2 break-words">
        {t.benefits.description}
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-12 sm:mb-16 w-full">
      
      <!-- Benefit 1: AI-Accelerated -->
      <div class="benefit-card rounded-xl p-4 sm:p-6 group w-full">
        <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary-400/20 rounded-lg flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-primary-400/40 transition-colors duration-300 flex-shrink-0">
          <svg class="w-5 sm:w-6 h-5 sm:h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-base sm:text-lg font-semibold text-white mb-2 break-words">{t.benefits.b1Title}</h3>
        <p class="text-gray-400 text-sm leading-relaxed break-words">
          {t.benefits.b1Text}
        </p>
      </div>

      <!-- Benefit 2: Business Impact -->
      <div class="benefit-card rounded-xl p-4 sm:p-6 group w-full">
        <div class="w-10 sm:w-12 h-10 sm:h-12 bg-blue-500/20 rounded-lg flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-blue-500/40 transition-colors duration-300 flex-shrink-0">
          <svg class="w-5 sm:w-6 h-5 sm:h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <h3 class="text-base sm:text-lg font-semibold text-white mb-2 break-words">{t.benefits.b2Title}</h3>
        <p class="text-gray-400 text-sm leading-relaxed break-words">
          {t.benefits.b2Text}
        </p>
      </div>

      <!-- Benefit 3: Full-Stack -->
      <div class="benefit-card rounded-xl p-4 sm:p-6 group w-full">
        <div class="w-10 sm:w-12 h-10 sm:h-12 bg-coral-400/20 rounded-lg flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-coral-400/40 transition-colors duration-300 flex-shrink-0">
          <svg class="w-5 sm:w-6 h-5 sm:h-6 text-coral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
        </div>
        <h3 class="text-base sm:text-lg font-semibold text-white mb-2 break-words">{t.benefits.b3Title}</h3>
        <p class="text-gray-400 text-sm leading-relaxed break-words">
          {t.benefits.b3Text}
        </p>
      </div>

      <!-- Benefit 4: Partnership -->
      <div class="benefit-card rounded-xl p-4 sm:p-6 group w-full">
        <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary-400/20 rounded-lg flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-primary-400/40 transition-colors duration-300 flex-shrink-0">
          <svg class="w-5 sm:w-6 h-5 sm:h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-base sm:text-lg font-semibold text-white mb-2 break-words">{t.benefits.b4Title}</h3>
        <p class="text-gray-400 text-sm leading-relaxed break-words">
          {t.benefits.b4Text}
        </p>
      </div>

    </div>

    <!-- Enhanced CTA -->
    <div class="text-center w-full">
      <h3 class="text-xl sm:text-2xl font-bold text-white mb-3 sm:mb-4 px-2 break-words">
        {t.benefits.bottomTitle}
      </h3>
      <p class="text-gray-400 mb-6 sm:mb-8 max-w-2xl mx-auto text-sm sm:text-base px-2 break-words">
        {t.benefits.bottomText}
      </p>
      
      <a href="#contact" class="liquid-cta-btn text-white px-6 sm:px-8 py-3 sm:py-4 rounded-lg text-base sm:text-lg font-semibold w-full sm:w-auto max-w-xs break-words inline-block text-center">
        {t.benefits.bottomCta}
      </a>
    </div>

  </div>
</section> 