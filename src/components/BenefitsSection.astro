---
// Benefits Section component - Results-driven benefits
---

<section class="py-20 lg:py-32 bg-background-secondary relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-6">
        Benefits That Drive
        <span class="bg-gradient-primary bg-clip-text text-transparent">Bottom-Line Results</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed">
        Every feature is designed to deliver measurable ROI. Here's exactly what Orion delivers for your business.
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      
      <!-- Benefit 1: Revenue Growth -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 group hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-16 h-16 bg-gradient-primary rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Revenue Growth</h3>
          <div class="text-3xl font-bold text-secondary-main mb-2">Average 40% Increase</div>
          <p class="text-text-secondary leading-relaxed mb-4">
            Accelerate sales cycles and capture more opportunities with intelligent lead scoring and automated follow-ups.
          </p>
          <div class="text-sm text-text-accent font-medium">
            ✓ Proof: 2,847 companies tracked for 12 months
          </div>
        </div>
      </div>

      <!-- Benefit 2: Cost Reduction -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 group hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-16 h-16 bg-gradient-accent rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Operating Cost Reduction</h3>
          <div class="text-3xl font-bold text-primary-main mb-2">Up to 60% Savings</div>
          <p class="text-text-secondary leading-relaxed mb-4">
            Eliminate manual processes and reduce human error costs with intelligent automation and validation.
          </p>
          <div class="text-sm text-text-accent font-medium">
            ✓ Proof: Averaged across 1,200+ implementations
          </div>
        </div>
      </div>

      <!-- Benefit 3: Time Savings -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 group hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-16 h-16 bg-secondary-main rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Productivity Multiplier</h3>
          <div class="text-3xl font-bold text-secondary-main mb-2">25+ Hours/Week</div>
          <p class="text-text-secondary leading-relaxed mb-4">
            Free your team from repetitive tasks to focus on high-value strategic work that drives innovation.
          </p>
          <div class="text-sm text-text-accent font-medium">
            ✓ Proof: Time-tracking analysis of 500+ teams
          </div>
        </div>
      </div>

      <!-- Benefit 4: Accuracy Improvement -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 group hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-16 h-16 bg-gradient-primary rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Error Elimination</h3>
          <div class="text-3xl font-bold text-primary-main mb-2">99.8% Accuracy</div>
          <p class="text-text-secondary leading-relaxed mb-4">
            Virtually eliminate human errors with AI-powered validation and automated quality checks.
          </p>
          <div class="text-sm text-text-accent font-medium">
            ✓ Proof: 10M+ transactions processed and verified
          </div>
        </div>
      </div>

      <!-- Benefit 5: Scalability -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 group hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-16 h-16 bg-gradient-accent rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Infinite Scale</h3>
          <div class="text-3xl font-bold text-secondary-main mb-2">10x Growth Ready</div>
          <p class="text-text-secondary leading-relaxed mb-4">
            Handle 10x volume without proportional cost increase. Built for companies that think big.
          </p>
          <div class="text-sm text-text-accent font-medium">
            ✓ Proof: Clients scaled from 10K to 100M+ transactions
          </div>
        </div>
      </div>

      <!-- Benefit 6: Decision Speed -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 group hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary-main/10">
        <div class="mb-6">
          <div class="w-16 h-16 bg-secondary-main rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary mb-3">Real-Time Intelligence</h3>
          <div class="text-3xl font-bold text-primary-main mb-2">5x Faster Decisions</div>
          <p class="text-text-secondary leading-relaxed mb-4">
            Get instant insights and alerts to make critical business decisions at the speed of opportunity.
          </p>
          <div class="text-sm text-text-accent font-medium">
            ✓ Proof: Decision latency analysis across industries
          </div>
        </div>
      </div>

    </div>

    <!-- ROI Calculator Teaser -->
    <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 lg:p-12 text-center">
      <h3 class="text-2xl lg:text-3xl font-bold text-text-primary mb-4">
        Calculate Your ROI
      </h3>
      <p class="text-lg text-text-secondary mb-6 leading-relaxed max-w-3xl mx-auto">
        See exactly how much Orion will save your business. Our ROI calculator uses real data from companies like yours.
      </p>
      
      <!-- Quick ROI Preview -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-background-secondary/50 rounded-xl p-6">
          <div class="text-2xl font-bold text-secondary-main mb-2">$2.4M</div>
          <div class="text-sm text-text-muted">Average Annual Savings</div>
        </div>
        <div class="bg-background-secondary/50 rounded-xl p-6">
          <div class="text-2xl font-bold text-primary-main mb-2">6 Months</div>
          <div class="text-sm text-text-muted">Typical Payback Period</div>
        </div>
        <div class="bg-background-secondary/50 rounded-xl p-6">
          <div class="text-2xl font-bold text-secondary-accent mb-2">420%</div>
          <div class="text-sm text-text-muted">3-Year ROI</div>
        </div>
      </div>

      <button class="bg-primary-main hover:bg-primary-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-main/30">
        Calculate My ROI
      </button>
    </div>

  </div>

  <!-- Background Effects -->
  <div class="absolute top-1/4 right-0 w-1/3 h-1/2 bg-gradient-radial opacity-20 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-1/4 h-1/3 bg-gradient-mesh opacity-10 pointer-events-none"></div>
</section> 