---
// Process Section component - Clean Minimal Style with ORION Theme Colors & Animations
---

<style>
  .process-section {
    background: linear-gradient(135deg, #1a1d21 0%, #2a2d32 25%, #232528 50%, #1e2124 75%, #1a1d21 100%);
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  /* Grid Pattern Overlay */
  .grid-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      linear-gradient(rgba(255, 164, 0, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 164, 0, 0.02) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.3;
    pointer-events: none;
  }

  /* Floating Orbs */
  .floating-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.4;
    animation: float 20s ease-in-out infinite;
  }

  .orb-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 164, 0, 0.15) 0%, rgba(255, 164, 0, 0.05) 40%, transparent 70%);
    top: 10%;
    left: -5%;
    animation-delay: 0s;
  }

  .orb-2 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(234, 246, 255, 0.1) 0%, rgba(234, 246, 255, 0.03) 40%, transparent 70%);
    top: 60%;
    right: -3%;
    animation-delay: -7s;
  }

  .orb-3 {
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(255, 164, 0, 0.08) 0%, rgba(255, 164, 0, 0.02) 40%, transparent 70%);
    top: 30%;
    left: 70%;
    animation-delay: -14s;
  }

  /* Stars */
  .star {
    position: absolute;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    animation: twinkle 4s ease-in-out infinite;
  }

  .star-small {
    width: 1px;
    height: 1px;
    animation-duration: 3s;
  }

  .star-medium {
    width: 2px;
    height: 2px;
    animation-duration: 5s;
  }

  .star-large {
    width: 3px;
    height: 3px;
    animation-duration: 6s;
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.5);
  }

  .star-amber {
    background: rgba(255, 164, 0, 0.6);
    box-shadow: 0 0 4px rgba(255, 164, 0, 0.3);
  }

  .star-blue {
    background: rgba(234, 246, 255, 0.7);
    box-shadow: 0 0 4px rgba(234, 246, 255, 0.2);
  }

  /* Ambient Particles */
  .ambient-particle {
    position: absolute;
    width: 2px;
    height: 2px;
    background: rgba(255, 164, 0, 0.6);
    border-radius: 50%;
    animation: particle-float 15s linear infinite;
  }

  .particle-1 { top: 20%; left: 10%; animation-delay: 0s; }
  .particle-2 { top: 40%; left: 30%; animation-delay: -3s; }
  .particle-3 { top: 60%; left: 60%; animation-delay: -6s; }
  .particle-4 { top: 80%; left: 20%; animation-delay: -9s; }
  .particle-5 { top: 30%; left: 80%; animation-delay: -12s; }

  /* Spotlight Effects */
  .spotlight {
    position: absolute;
    background: radial-gradient(ellipse at center, rgba(255, 164, 0, 0.1) 0%, rgba(255, 164, 0, 0.05) 30%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    animation: spotlight-pulse 8s ease-in-out infinite;
  }

  .spotlight-1 {
    width: 400px;
    height: 200px;
    top: -10%;
    left: 30%;
    animation-delay: 0s;
  }

  .spotlight-2 {
    width: 300px;
    height: 150px;
    bottom: -5%;
    right: 20%;
    animation-delay: -4s;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px) translateX(0px) scale(1);
    }
    25% {
      transform: translateY(-20px) translateX(10px) scale(1.1);
    }
    50% {
      transform: translateY(-10px) translateX(-15px) scale(0.9);
    }
    75% {
      transform: translateY(-30px) translateX(5px) scale(1.05);
    }
  }

  @keyframes twinkle {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  @keyframes particle-float {
    0% {
      transform: translateY(0px) translateX(0px);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(-100px) translateX(20px);
      opacity: 0;
    }
  }

  @keyframes spotlight-pulse {
    0%, 100% {
      opacity: 0.2;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(1.2);
    }
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .section-badge {
    background: rgba(255, 164, 0, 0.1);
    border: 1px solid rgba(255, 164, 0, 0.3);
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  
  .section-badge::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 164, 0, 0.2), transparent);
    transition: left 0.6s ease;
  }
  
  .section-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(255, 164, 0, 0.2);
  }
  
  .section-badge:hover::before {
    left: 100%;
  }
  
  .section-badge-dot {
    width: 8px;
    height: 8px;
    background: #FFA400;
    border-radius: 50%;
    animation: pulseGlow 2s infinite;
  }
  
  @keyframes pulseGlow {
    0%, 100% { 
      opacity: 1;
      transform: scale(1);
      box-shadow: 0 0 0 rgba(255, 164, 0, 0.7);
    }
    50% { 
      opacity: 0.8;
      transform: scale(1.1);
      box-shadow: 0 0 10px rgba(255, 164, 0, 0.7);
    }
  }
  
  .main-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.2;
    margin-bottom: 1rem;
    animation: slideInFromLeft 0.8s ease-out 0.4s backwards;
  }
  
  @media (min-width: 640px) {
    .main-title {
      font-size: 1.875rem;
    }
  }
  
  @media (min-width: 1024px) {
    .main-title {
      font-size: 2.25rem;
    }
  }
  
  .title-highlight {
    background: linear-gradient(135deg, #FFA400 0%, #EAF6FF 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 200%;
    animation: gradientShift 3s ease-in-out infinite;
  }
  
  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  
  .main-subtitle {
    font-size: 0.875rem;
    color: #d1d5db;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    animation: fadeIn 0.8s ease-out 0.6s backwards;
  }
  
  @media (min-width: 640px) {
    .main-subtitle {
      font-size: 1rem;
    }
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  .process-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .process-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    margin-bottom: 2.5rem;
    padding: 1rem 0;
  }
  
  .process-step:nth-child(even) {
    direction: rtl;
  }
  
  .process-step:nth-child(even) .step-content {
    direction: ltr;
  }
  
  @media (max-width: 768px) {
    .process-step {
      grid-template-columns: 1fr;
      gap: 1.2rem;
      text-align: center;
    }
    
    .process-step:nth-child(even) {
      direction: ltr;
    }
  }
  
  .step-content {
    padding: 1rem 0;
  }
  
  @media (max-width: 768px) {
    .step-content {
      text-align: center;
      margin: 0 auto;
    }
    
    .step-description {
      margin: 0 auto;
    }
  }
  
  .step-number {
    font-size: 1rem;
    font-weight: 700;
    color: #FFA400;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  .step-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.7rem;
    line-height: 1.3;
    transition: color 0.3s ease;
    cursor: default;
  }
  
  @media (min-width: 640px) {
    .step-title {
      font-size: 0.875rem;
    }
  }
  
  .step-title:hover {
    color: #FFA400;
    text-shadow: 0 0 20px rgba(255, 164, 0, 0.3);
  }
  
  .step-description {
    font-size: 0.75rem;
    color: #d1d5db;
    line-height: 1.7;
    max-width: 350px;
    transition: color 0.3s ease;
  }
  
  .step-content:hover .step-description {
    color: #ffffff;
  }
  
  .step-visual {
    position: relative;
    height: 200px;
    background: linear-gradient(135deg, 
      rgba(255, 164, 0, 0.1) 0%, 
      rgba(234, 246, 255, 0.1) 100%);
    border: 1px solid rgba(255, 164, 0, 0.2);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
    transition: all 0.4s ease;
  }
  
  .step-visual:hover {
    transform: translateY(-15px) scale(1.02);
    box-shadow: 0 20px 40px rgba(255, 164, 0, 0.15);
    border-color: rgba(255, 164, 0, 0.4);
  }
  
  .step-visual::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      linear-gradient(45deg, transparent 48%, rgba(255, 164, 0, 0.05) 49%, rgba(255, 164, 0, 0.05) 51%, transparent 52%),
      linear-gradient(-45deg, transparent 48%, rgba(234, 246, 255, 0.05) 49%, rgba(234, 246, 255, 0.05) 51%, transparent 52%);
    background-size: 60px 60px;
    opacity: 0.3;
  }
  
  .visual-icon {
    font-size: 2rem;
    background: linear-gradient(135deg, #FFA400 0%, #EAF6FF 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    z-index: 2;
    position: relative;
    transition: all 0.3s ease;
  }
  
  .step-visual:hover .visual-icon {
    transform: scale(1.1) rotate(5deg);
  }
  
  .visual-content {
    position: absolute;
    inset: 0.7rem;
    background: rgba(35, 37, 40, 0.3);
    border: 1px solid rgba(255, 164, 0, 0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
    backdrop-filter: blur(5px);
    transition: all 0.3s ease;
  }
  
  .step-visual:hover .visual-content {
    background: rgba(35, 37, 40, 0.6);
    border-color: rgba(255, 164, 0, 0.3);
  }
  
  .visual-text {
    color: #d1d5db;
    font-size: 0.75rem;
    text-align: center;
    opacity: 0.7;
    transition: all 0.3s ease;
  }
  
  .step-visual:hover .visual-text {
    opacity: 1;
    color: #FFA400;
  }
  
  /* Step-specific styling */
  .step-1 .step-visual {
    background: linear-gradient(135deg, 
      rgba(255, 164, 0, 0.15) 0%, 
      rgba(234, 246, 255, 0.05) 100%);
    border-color: rgba(255, 164, 0, 0.3);
  }
  
  .step-2 .step-visual {
    background: linear-gradient(135deg, 
      rgba(234, 246, 255, 0.15) 0%, 
      rgba(255, 164, 0, 0.05) 100%);
    border-color: rgba(234, 246, 255, 0.3);
  }
  
  .step-3 .step-visual {
    background: linear-gradient(135deg, 
      rgba(255, 164, 0, 0.12) 0%, 
      rgba(234, 246, 255, 0.08) 100%);
    border-color: rgba(255, 164, 0, 0.25);
  }
  
  .step-4 .step-visual {
    background: linear-gradient(135deg, 
      rgba(234, 246, 255, 0.12) 0%, 
      rgba(255, 164, 0, 0.08) 100%);
    border-color: rgba(234, 246, 255, 0.25);
  }
  
  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, 
      rgba(255, 164, 0, 0.1) 0%, 
      rgba(234, 246, 255, 0.1) 100%);
    border: 1px solid rgba(255, 164, 0, 0.2);
    border-radius: 14px;
    padding: 2rem 1.2rem;
    text-align: center;
    margin-top: 2.5rem;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.8s ease-out 1.6s forwards;
  }
  
  .cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 50% 50%, rgba(255, 164, 0, 0.05) 0%, transparent 70%);
    pointer-events: none;
    animation: pulse 4s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }
  
  .cta-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 0.5rem;
    animation: slideInFromBottom 0.6s ease-out 1.8s backwards;
  }
  
  @media (min-width: 640px) {
    .cta-title {
      font-size: 1.875rem;
    }
  }
  
  @media (min-width: 1024px) {
    .cta-title {
      font-size: 2.25rem;
    }
  }
  
  @keyframes slideInFromBottom {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .cta-subtitle {
    font-size: 0.875rem;
    color: #d1d5db;
    margin-bottom: 1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeIn 0.6s ease-out 2.0s backwards;
  }
  
  @media (min-width: 640px) {
    .cta-subtitle {
      font-size: 1rem;
    }
  }
  
  .cta-button {
    background: linear-gradient(135deg, #FFA400 0%, #EAF6FF 100%);
    border: none;
    border-radius: 8px;
    padding: 0.7rem 1.5rem;
    color: #000000;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.4s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(255, 164, 0, 0.3);
    position: relative;
    z-index: 2;
    animation: scaleIn 0.6s ease-out 2.2s backwards;
    overflow: hidden;
  }
  
  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  .cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.6s ease;
  }
  
  .cta-button:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 15px 35px rgba(255, 164, 0, 0.4);
    background: linear-gradient(135deg, #f59e0b 0%, #dbeafe 100%);
  }
  
  .cta-button:hover::before {
    left: 100%;
  }
  
  .cta-button svg {
    transition: transform 0.3s ease;
  }
  
  .cta-button:hover svg {
    transform: translateX(5px);
  }
  
  .cta-features {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 2.4s backwards;
  }
  
  .cta-feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #d1d5db;
    font-size: 0.75rem;
    transition: all 0.3s ease;
    opacity: 0;
    animation: slideInFeature 0.4s ease-out forwards;
  }
  
  @media (min-width: 640px) {
    .cta-feature {
      font-size: 0.875rem;
    }
  }
  
  .cta-feature:nth-child(1) { animation-delay: 2.6s; }
  .cta-feature:nth-child(2) { animation-delay: 2.8s; }
  .cta-feature:nth-child(3) { animation-delay: 3.0s; }
  
  @keyframes slideInFeature {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }
  
  .cta-feature:hover {
    color: #FFA400;
    transform: translateY(-2px);
  }
  
  .cta-feature-icon {
    width: 13px;
    height: 13px;
    background: #FFA400;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    color: #000000;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  
  .cta-feature:hover .cta-feature-icon {
    transform: scale(1.2) rotate(360deg);
    box-shadow: 0 4px 12px rgba(255, 164, 0, 0.4);
  }
  
  /* Scroll reveal animations */
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease-out;
  }
  
  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Add the underline animation */
  @keyframes scaleX {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
</style>

<section id="process" class="process-section">
  <!-- Background Elements -->
  <div class="grid-pattern"></div>
  
  <!-- Floating Orbs -->
  <div class="floating-orb orb-1"></div>
  <div class="floating-orb orb-2"></div>
  <div class="floating-orb orb-3"></div>
  
  <!-- Spotlight Effects -->
  <div class="spotlight spotlight-1"></div>
  <div class="spotlight spotlight-2"></div>
  
  <!-- Ambient Particles -->
  <div class="ambient-particle particle-1"></div>
  <div class="ambient-particle particle-2"></div>
  <div class="ambient-particle particle-3"></div>
  <div class="ambient-particle particle-4"></div>
  <div class="ambient-particle particle-5"></div>
  
  <!-- Stars -->
  <div class="star star-small" style="top: 15%; left: 8%;"></div>
  <div class="star star-medium star-amber" style="top: 25%; left: 85%;"></div>
  <div class="star star-small" style="top: 35%; left: 15%;"></div>
  <div class="star star-large star-blue" style="top: 45%; left: 75%;"></div>
  <div class="star star-small" style="top: 55%; left: 5%;"></div>
  <div class="star star-medium" style="top: 65%; left: 90%;"></div>
  <div class="star star-small star-amber" style="top: 75%; left: 25%;"></div>
  <div class="star star-small" style="top: 85%; left: 65%;"></div>
  <div class="star star-medium star-blue" style="top: 10%; left: 45%;"></div>
  <div class="star star-small" style="top: 20%; left: 65%;"></div>
  <div class="star star-large" style="top: 30%; left: 35%;"></div>
  <div class="star star-small star-amber" style="top: 40%; left: 95%;"></div>
  <div class="star star-medium" style="top: 50%; left: 55%;"></div>
  <div class="star star-small" style="top: 60%; left: 12%;"></div>
  <div class="star star-small star-blue" style="top: 70%; left: 80%;"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24">
    <!-- Section Header -->
    <div class="section-header">
      <div class="section-badge">
        <div class="section-badge-dot"></div>
        <span class="text-primary-main text-sm font-medium">Our MVP Process</span>
      </div>
      <h2 class="main-title">
        From Idea to 
        <div class="relative inline-block">
          <span class="text-white font-bold relative">
            <span class="relative z-10">Launch in 6-8 Weeks</span>
            <div 
              class="absolute bottom-[6px] left-0 w-full h-[0.15em] bg-primary-400 transform origin-left z-0"
              style="animation: scaleX 0.4s ease-out 1.4s forwards;"
            ></div>
          </span>
        </div>
      </h2>
      <p class="main-subtitle">
        Our battle-tested process turns your SaaS vision into reality with speed and precision. No cutting corners, just smart execution.
      </p>
    </div>

    <!-- Process Steps -->
    <div class="process-container">
      <!-- Step 1: Strategy -->
      <div class="process-step">
        <div class="step-content">
          <div class="step-number">Week 1</div>
          <h3 class="step-title">Strategic Planning & Architecture</h3>
          <p class="step-description">
            We start with a deep dive into your vision. Define core features, map user journeys, and design scalable architecture that won't need a rewrite at 100K users.
          </p>
        </div>
        <div class="step-visual">
          <div class="visual-container">
            <svg class="w-full h-full" viewBox="0 0 400 300" fill="none">
              <!-- Strategy visualization -->
              <rect x="50" y="50" width="300" height="200" rx="20" class="stroke-primary-main/30" stroke-width="2" stroke-dasharray="5 5"/>
              <circle cx="200" cy="150" r="60" class="fill-primary-main/10 stroke-primary-main" stroke-width="2"/>
              <path d="M200 110 L200 190 M170 150 L230 150" class="stroke-primary-main" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Step 2: Development -->
      <div class="process-step">
