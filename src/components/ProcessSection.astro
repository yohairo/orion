---
// Process Section component with step-by-step methodology
---

<section class="py-20 lg:py-32 bg-background-primary relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-6">
        Our Proven
        <span class="bg-gradient-primary bg-clip-text text-transparent">Implementation Process</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed">
        Complete transparency from day one. Here's exactly how we deliver results in 90 days or less.
      </p>
    </div>

    <!-- Process Steps -->
    <div class="relative">
      <!-- Progress Line -->
      <div class="absolute left-1/2 transform -translate-x-0.5 top-16 bottom-16 w-0.5 bg-gradient-to-b from-primary-main via-secondary-main to-primary-main hidden lg:block"></div>
      
      <!-- Steps Grid -->
      <div class="space-y-16 lg:space-y-24">
        
        <!-- Step 1: Discovery & Analysis -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="lg:text-right lg:pr-16">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-primary rounded-2xl mb-6 lg:ml-auto">
              <span class="text-white text-2xl font-bold">1</span>
            </div>
            <h3 class="text-2xl font-bold text-text-primary mb-4">Discovery & Analysis</h3>
            <p class="text-text-secondary mb-6 leading-relaxed">
              We audit your current processes and identify the highest-impact automation opportunities. Our team analyzes your workflows, pain points, and growth goals to create a custom optimization roadmap.
            </p>
            <div class="space-y-3">
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Process mapping & bottleneck identification</span>
              </div>
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">ROI potential assessment</span>
              </div>
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Success metrics definition</span>
              </div>
            </div>
            <div class="mt-6 text-sm text-primary-main font-semibold">
              Timeline: 1-2 weeks
            </div>
          </div>
          <div class="lg:pl-16">
            <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <h4 class="font-semibold text-text-primary">Process Audit Report</h4>
                  <div class="w-3 h-3 bg-secondary-main rounded-full animate-pulse"></div>
                </div>
                <div class="space-y-3">
                  <div class="bg-background-secondary rounded-lg p-3">
                    <div class="h-2 bg-text-muted/20 rounded mb-2"></div>
                    <div class="h-1 bg-primary-main/30 rounded w-3/4"></div>
                  </div>
                  <div class="bg-background-secondary rounded-lg p-3">
                    <div class="h-2 bg-text-muted/20 rounded mb-2"></div>
                    <div class="h-1 bg-secondary-main/30 rounded w-2/3"></div>
                  </div>
                  <div class="bg-background-secondary rounded-lg p-3">
                    <div class="h-2 bg-text-muted/20 rounded mb-2"></div>
                    <div class="h-1 bg-text-accent/30 rounded w-4/5"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2: Strategy & Design -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="lg:order-2 lg:pl-16">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-accent rounded-2xl mb-6">
              <span class="text-white text-2xl font-bold">2</span>
            </div>
            <h3 class="text-2xl font-bold text-text-primary mb-4">Strategy & Design</h3>
            <p class="text-text-secondary mb-6 leading-relaxed">
              We design your automated workflows with precision. Every automation is custom-built for your specific business logic, ensuring maximum efficiency and seamless integration with existing systems.
            </p>
            <div class="space-y-3">
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Custom workflow architecture</span>
              </div>
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Integration mapping & API design</span>
              </div>
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Security & compliance framework</span>
              </div>
            </div>
            <div class="mt-6 text-sm text-primary-main font-semibold">
              Timeline: 2-3 weeks
            </div>
          </div>
          <div class="lg:order-1 lg:pr-16">
            <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <h4 class="font-semibold text-text-primary">Workflow Designer</h4>
                  <div class="flex space-x-1">
                    <div class="w-2 h-2 bg-red-500 rounded-full"></div>
                    <div class="w-2 h-2 bg-yellow-500 rounded-full"></div>
                    <div class="w-2 h-2 bg-secondary-main rounded-full"></div>
                  </div>
                </div>
                <div class="space-y-3">
                  <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-primary-main rounded-lg flex items-center justify-center">
                      <span class="text-white text-xs">S</span>
                    </div>
                    <div class="flex-1 h-2 bg-primary-main/30 rounded"></div>
                    <div class="w-8 h-8 bg-secondary-main rounded-lg flex items-center justify-center">
                      <span class="text-white text-xs">P</span>
                    </div>
                  </div>
                  <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-background-secondary rounded-lg border-2 border-dashed border-border-primary"></div>
                    <div class="flex-1 h-2 bg-text-muted/20 rounded"></div>
                    <div class="w-8 h-8 bg-text-accent rounded-lg flex items-center justify-center">
                      <span class="text-white text-xs">E</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3: Development & Testing -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="lg:text-right lg:pr-16">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-secondary-main rounded-2xl mb-6 lg:ml-auto">
              <span class="text-white text-2xl font-bold">3</span>
            </div>
            <h3 class="text-2xl font-bold text-text-primary mb-4">Development & Testing</h3>
            <p class="text-text-secondary mb-6 leading-relaxed">
              Our expert team builds and rigorously tests your automation systems. We use industry best practices for testing, ensuring 99.9% reliability before any system goes live in your environment.
            </p>
            <div class="space-y-3">
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Agile development methodology</span>
              </div>
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Comprehensive QA testing</span>
              </div>
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">User acceptance testing</span>
              </div>
            </div>
            <div class="mt-6 text-sm text-primary-main font-semibold">
              Timeline: 3-4 weeks
            </div>
          </div>
          <div class="lg:pl-16">
            <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <h4 class="font-semibold text-text-primary">Testing Dashboard</h4>
                  <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 bg-secondary-main rounded-full animate-pulse"></div>
                    <span class="text-xs text-secondary-main">Running</span>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div class="bg-background-secondary rounded-lg p-3 text-center">
                    <div class="text-lg font-bold text-secondary-main">98.7%</div>
                    <div class="text-xs text-text-muted">Test Coverage</div>
                  </div>
                  <div class="bg-background-secondary rounded-lg p-3 text-center">
                    <div class="text-lg font-bold text-primary-main">847</div>
                    <div class="text-xs text-text-muted">Tests Passed</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 4: Deployment & Training -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="lg:order-2 lg:pl-16">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-primary rounded-2xl mb-6">
              <span class="text-white text-2xl font-bold">4</span>
            </div>
            <h3 class="text-2xl font-bold text-text-primary mb-4">Deployment & Training</h3>
            <p class="text-text-secondary mb-6 leading-relaxed">
              Seamless deployment with zero downtime. We handle the technical migration while training your team on the new systems. Every team member gets hands-on training tailored to their role.
            </p>
            <div class="space-y-3">
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Phased deployment strategy</span>
              </div>
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Comprehensive team training</span>
              </div>
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Documentation & support materials</span>
              </div>
            </div>
            <div class="mt-6 text-sm text-primary-main font-semibold">
              Timeline: 1-2 weeks
            </div>
          </div>
          <div class="lg:order-1 lg:pr-16">
            <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <h4 class="font-semibold text-text-primary">Deployment Status</h4>
                  <div class="text-xs text-secondary-main font-medium">Live</div>
                </div>
                <div class="space-y-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-text-secondary">Environment Setup</span>
                    <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center">
                      <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                      </svg>
                    </div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-text-secondary">Data Migration</span>
                    <div class="w-6 h-6 bg-secondary-main rounded-full flex items-center justify-center">
                      <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                      </svg>
                    </div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-text-secondary">Team Training</span>
                    <div class="w-6 h-6 bg-primary-main rounded-full flex items-center justify-center animate-pulse">
                      <div class="w-2 h-2 bg-white rounded-full"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 5: Optimization & Support -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="lg:text-right lg:pr-16">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-accent rounded-2xl mb-6 lg:ml-auto">
              <span class="text-white text-2xl font-bold">5</span>
            </div>
            <h3 class="text-2xl font-bold text-text-primary mb-4">Optimization & Support</h3>
            <p class="text-text-secondary mb-6 leading-relaxed">
              Continuous improvement never stops. We monitor performance, identify optimization opportunities, and provide ongoing support. Your system gets smarter and more efficient over time.
            </p>
            <div class="space-y-3">
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">24/7 monitoring & alerts</span>
              </div>
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Performance optimization</span>
              </div>
              <div class="flex items-center lg:justify-end space-x-3">
                <svg class="w-5 h-5 text-secondary-main" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-text-secondary">Dedicated account management</span>
              </div>
            </div>
            <div class="mt-6 text-sm text-primary-main font-semibold">
              Timeline: Ongoing
            </div>
          </div>
          <div class="lg:pl-16">
            <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-6 hover:border-border-accent transition-all duration-300">
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <h4 class="font-semibold text-text-primary">Performance Monitor</h4>
                  <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 bg-secondary-main rounded-full animate-pulse"></div>
                    <span class="text-xs text-secondary-main">Optimizing</span>
                  </div>
                </div>
                <div class="space-y-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-text-secondary">Efficiency</span>
                    <span class="text-sm font-semibold text-secondary-main">+23%</span>
                  </div>
                  <div class="w-full bg-background-secondary rounded-full h-2">
                    <div class="bg-secondary-main h-2 rounded-full" style="width: 85%"></div>
                  </div>
                  <div class="text-xs text-text-muted">Last optimization: 2 hours ago</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-20">
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 lg:p-12">
        <h3 class="text-2xl lg:text-3xl font-bold text-text-primary mb-4">
          Ready to Start Your Transformation?
        </h3>
        <p class="text-lg text-text-secondary mb-8 leading-relaxed max-w-2xl mx-auto">
          Our process is designed for success. Join 2,800+ companies who have transformed their operations with Orion.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
          <button class="bg-primary-main hover:bg-primary-dark text-white px-8 py-4 rounded-xl text-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-main/30">
            Book Discovery Call
          </button>
          <button class="border border-border-accent hover:border-primary-main bg-background-glassmorphism backdrop-blur-sm text-text-primary px-8 py-4 rounded-xl text-lg font-semibold transition-all duration-300 hover:bg-background-secondary/50">
            Download Process Guide
          </button>
        </div>
      </div>
    </div>

  </div>

  <!-- Background Effects -->
  <div class="absolute top-0 right-0 w-1/4 h-1/2 bg-gradient-radial opacity-20 pointer-events-none"></div>
  <div class="absolute bottom-1/4 left-0 w-1/3 h-1/3 bg-gradient-mesh opacity-10 pointer-events-none"></div>
</section> 