---
import { Image } from 'astro:assets';
import aiFileSystem from '../assets/ai-file-system.webp';
import invoiceExtractor from '../assets/invoice-extractor.webp';
import residentialManagement from '../assets/residential-management.webp';
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);
---

<style>
    .star-border {
    position: relative;
    border: 1px solid transparent;
          background: linear-gradient(#27272a, #27272a) padding-box,
                  linear-gradient(90deg, 
                    transparent, 
                    rgba(255, 164, 0, var(--glow-opacity, 0)), 
                    transparent) border-box;
    background-size: 100% 100%, 400% 100%;
          animation: star-sweep 30s ease-in-out infinite;
    transition: all 0.3s ease;
  }
  
  .star-border:hover {
    box-shadow: 0 0 20px rgba(255, 164, 0, 0.4);
  }
  
  @keyframes star-sweep {
    0% {
      background-position: 0% 0%, -400% 0%;
      --glow-opacity: 0;
    }
    20% {
      --glow-opacity: 0.8;
    }
    40% {
      background-position: 0% 0%, 200% 0%;
      --glow-opacity: 1;
    }
    60% {
      background-position: 0% 0%, 400% 0%;
      --glow-opacity: 0.8;
    }
    75% {
      --glow-opacity: 0;
    }
    100% {
      background-position: 0% 0%, -400% 0%;
      --glow-opacity: 0;
    }
  }
  
  /* Liquid Glass Button Styles */
  .liquid-glass-btn {
    background: rgba(255, 164, 0, 0.15);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 164, 0, 0.3);
    box-shadow: 0 8px 32px rgba(255, 164, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }
  
  .liquid-glass-btn:hover {
    transform: scale(1.05);
  }
  
  .glass-overlay {
    background: linear-gradient(45deg, rgba(255, 164, 0, 0.1) 0%, rgba(234, 246, 255, 0.05) 50%, rgba(255, 164, 0, 0.1) 100%);
    animation: glass-pulse 2s ease-in-out infinite;
  }
  
  .glass-reflection {
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.2) 50%, transparent 100%);
  }
  
  .glass-edge {
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.1) 0%, transparent 50%, rgba(255, 164, 0, 0.1) 100%);
  }
  
  @keyframes glass-pulse {
    0% {
      background: linear-gradient(45deg, rgba(255, 164, 0, 0.1) 0%, rgba(234, 246, 255, 0.05) 50%, rgba(255, 164, 0, 0.1) 100%);
    }
    50% {
      background: linear-gradient(225deg, rgba(255, 164, 0, 0.2) 0%, rgba(234, 246, 255, 0.1) 50%, rgba(255, 164, 0, 0.15) 100%);
    }
    100% {
      background: linear-gradient(45deg, rgba(255, 164, 0, 0.1) 0%, rgba(234, 246, 255, 0.05) 50%, rgba(255, 164, 0, 0.1) 100%);
    }
  }
  
  /* Background Styles */
  .case-studies-bg {
    background: linear-gradient(135deg, #1a1d21 0%, #2a2d32 25%, #232528 50%, #1e2124 75%, #1a1d21 100%);
    position: relative;
  }
  
  .case-studies-bg::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 20%, rgba(255, 164, 0, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(234, 246, 255, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(255, 164, 0, 0.03) 0%, transparent 70%);
    pointer-events: none;
  }
  
  /* Floating Orbs */
  .floating-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.4;
    animation: float 20s ease-in-out infinite;
  }
  
  .orb-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 164, 0, 0.15) 0%, rgba(255, 164, 0, 0.05) 40%, transparent 70%);
    top: 10%;
    left: -5%;
    animation-delay: 0s;
  }
  
  .orb-2 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(234, 246, 255, 0.1) 0%, rgba(234, 246, 255, 0.03) 40%, transparent 70%);
    top: 60%;
    right: -3%;
    animation-delay: -7s;
  }
  
  .orb-3 {
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(255, 164, 0, 0.08) 0%, rgba(255, 164, 0, 0.02) 40%, transparent 70%);
    top: 30%;
    left: 70%;
    animation-delay: -14s;
  }
  
  /* Grid Pattern Overlay */
  .grid-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      linear-gradient(rgba(255, 164, 0, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 164, 0, 0.02) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.3;
    pointer-events: none;
  }
  
  /* Ambient Particles */
  .ambient-particle {
    position: absolute;
    width: 2px;
    height: 2px;
    background: rgba(255, 164, 0, 0.6);
    border-radius: 50%;
    animation: particle-float 15s linear infinite;
  }
  
  .particle-1 { top: 20%; left: 10%; animation-delay: 0s; }
  .particle-2 { top: 40%; left: 30%; animation-delay: -3s; }
  .particle-3 { top: 60%; left: 60%; animation-delay: -6s; }
  .particle-4 { top: 80%; left: 20%; animation-delay: -9s; }
  .particle-5 { top: 30%; left: 80%; animation-delay: -12s; }
  
  @keyframes float {
    0%, 100% {
      transform: translateY(0px) translateX(0px) scale(1);
    }
    25% {
      transform: translateY(-20px) translateX(10px) scale(1.1);
    }
    50% {
      transform: translateY(-10px) translateX(-15px) scale(0.9);
    }
    75% {
      transform: translateY(-30px) translateX(5px) scale(1.05);
    }
  }
  
  @keyframes particle-float {
    0% {
      transform: translateY(0px) translateX(0px);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(-100px) translateX(20px);
      opacity: 0;
    }
  }
  
  /* Spotlight Effects */
  .spotlight {
    position: absolute;
    background: radial-gradient(ellipse at center, rgba(255, 164, 0, 0.1) 0%, rgba(255, 164, 0, 0.05) 30%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    animation: spotlight-pulse 8s ease-in-out infinite;
  }
  
  .spotlight-1 {
    width: 400px;
    height: 200px;
    top: -10%;
    left: 30%;
    animation-delay: 0s;
  }
  
  .spotlight-2 {
    width: 300px;
    height: 150px;
    bottom: -5%;
    right: 20%;
    animation-delay: -4s;
  }
  
  @keyframes spotlight-pulse {
    0%, 100% {
      opacity: 0.2;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(1.2);
    }
  }
  
  /* Stars */
  .star {
    position: absolute;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    animation: twinkle 4s ease-in-out infinite;
  }
  
  .star-small {
    width: 1px;
    height: 1px;
    animation-duration: 3s;
  }
  
  .star-medium {
    width: 2px;
    height: 2px;
    animation-duration: 5s;
  }
  
  .star-large {
    width: 3px;
    height: 3px;
    animation-duration: 6s;
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.5);
  }
  
  .star-amber {
    background: rgba(255, 164, 0, 0.6);
    box-shadow: 0 0 4px rgba(255, 164, 0, 0.3);
  }
  
  .star-blue {
    background: rgba(234, 246, 255, 0.7);
    box-shadow: 0 0 4px rgba(234, 246, 255, 0.2);
  }
  
  @keyframes twinkle {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }
  
  .star:nth-child(2n) { animation-delay: -1s; }
  .star:nth-child(3n) { animation-delay: -2s; }
  .star:nth-child(4n) { animation-delay: -3s; }
  .star:nth-child(5n) { animation-delay: -0.5s; }
  .star:nth-child(6n) { animation-delay: -1.5s; }
</style>

<section id="case-studies" class="min-h-screen flex items-center case-studies-bg py-20 lg:py-32 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="grid-pattern"></div>
  
  <!-- Floating Orbs -->
  <div class="floating-orb orb-1"></div>
  <div class="floating-orb orb-2"></div>
  <div class="floating-orb orb-3"></div>
  
  <!-- Spotlight Effects -->
  <div class="spotlight spotlight-1"></div>
  <div class="spotlight spotlight-2"></div>
  
  <!-- Ambient Particles -->
  <div class="ambient-particle particle-1"></div>
  <div class="ambient-particle particle-2"></div>
  <div class="ambient-particle particle-3"></div>
  <div class="ambient-particle particle-4"></div>
  <div class="ambient-particle particle-5"></div>
  
  <!-- Stars -->
  <div class="star star-small" style="top: 15%; left: 8%;"></div>
  <div class="star star-medium star-amber" style="top: 25%; left: 85%;"></div>
  <div class="star star-small" style="top: 35%; left: 15%;"></div>
  <div class="star star-large star-blue" style="top: 45%; left: 75%;"></div>
  <div class="star star-small" style="top: 55%; left: 5%;"></div>
  <div class="star star-medium" style="top: 65%; left: 90%;"></div>
  <div class="star star-small star-amber" style="top: 75%; left: 25%;"></div>
  <div class="star star-small" style="top: 85%; left: 65%;"></div>
  <div class="star star-medium star-blue" style="top: 10%; left: 45%;"></div>
  <div class="star star-small" style="top: 20%; left: 65%;"></div>
  <div class="star star-large" style="top: 30%; left: 35%;"></div>
  <div class="star star-small star-amber" style="top: 40%; left: 95%;"></div>
  <div class="star star-medium" style="top: 50%; left: 55%;"></div>
  <div class="star star-small" style="top: 60%; left: 12%;"></div>
  <div class="star star-small star-blue" style="top: 70%; left: 80%;"></div>
  <div class="star star-medium" style="top: 80%; left: 40%;"></div>
  <div class="star star-small" style="top: 90%; left: 70%;"></div>
  <div class="star star-large star-amber" style="top: 5%; left: 25%;"></div>
  <div class="star star-small" style="top: 95%; left: 15%;"></div>
  <div class="star star-medium star-blue" style="top: 18%; left: 95%;"></div>
  <div class="star star-small" style="top: 28%; left: 58%;"></div>
  <div class="star star-medium star-amber" style="top: 38%; left: 8%;"></div>
  <div class="star star-small" style="top: 48%; left: 88%;"></div>
  <div class="star star-large star-blue" style="top: 58%; left: 38%;"></div>
  <div class="star star-small" style="top: 68%; left: 98%;"></div>
  <div class="star star-medium" style="top: 78%; left: 18%;"></div>
  <div class="star star-small star-amber" style="top: 88%; left: 48%;"></div>
  <div class="star star-small" style="top: 12%; left: 78%;"></div>
  <div class="star star-medium star-blue" style="top: 22%; left: 32%;"></div>
  <div class="star star-small" style="top: 32%; left: 92%;"></div>
  <div class="star star-large" style="top: 42%; left: 22%;"></div>
  <div class="star star-small star-amber" style="top: 52%; left: 72%;"></div>
  <div class="star star-medium" style="top: 62%; left: 2%;"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
    
    <!-- Section Header -->
    <div class="text-center mb-16 sm:mb-20 lg:mb-24 ">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 sm:mb-6 px-2 break-words">
        {t.caseStudies.headline1}
        <div class="relative inline-block">
          <span class="text-white font-bold relative">
            <span class="relative z-10">{t.caseStudies.headlineHighlight}</span>
            <div 
              class="absolute bottom-[6px] left-0 w-full h-[0.15em] bg-primary-400 transform origin-left z-0"
              style="animation: scaleX 0.4s ease-out 1.4s forwards;"
            ></div>
          </span>
        </div>
      </h2>
      <p class="text-lg sm:text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed px-2 break-words">
        {t.caseStudies.description}
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 w-full">
      
      <!-- Project 1: AI Files Management -->
      <div class="star-border group relative bg-gray-800 rounded-2xl overflow-hidden border border-gray-700 hover:border-transparent transition-all duration-500 cursor-pointer w-full" data-modal="modal1">
        <!-- Project Image -->
        <div class="aspect-[4/5] bg-gray-800 relative overflow-hidden">
          <Image 
            src={aiFileSystem}
            alt={t.caseStudies.project1Alt}
            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-110 group-hover:blur-sm"
            quality={90}
            format="webp"
          />
          <!-- Hover Overlay -->
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-between p-4 sm:p-6">
            <div class="w-full flex justify-center">
              <h3 class="text-xl sm:text-2xl font-bold text-white mb-2 break-words text-center">{t.caseStudies.project1Title}</h3>
            </div>
            <div class="flex items-end justify-between w-full">
              <!-- Logo bottom left -->
              <div class="flex items-center flex-shrink-0">
                <svg class="w-8 sm:w-10 h-8 sm:h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <!-- Button bottom right -->
              <button class="liquid-glass-btn relative px-4 sm:px-6 py-2 rounded-xl font-semibold transition-all duration-300 ml-auto text-sm sm:text-base whitespace-nowrap overflow-hidden group">
                <!-- Liquid glass background overlay -->
                <div class="absolute inset-0 rounded-xl glass-overlay opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                
                <!-- Liquid light reflection -->
                <div class="absolute top-0 left-[-100%] w-full h-full glass-reflection transform -skew-x-12 group-hover:left-[100%] transition-all duration-600 ease-out"></div>
                
                <!-- Button content -->
                <span class="relative z-10 text-white font-medium">{t.caseStudies.seeMore}</span>
                
                <!-- Glass edge highlight -->
                <div class="absolute inset-0 rounded-xl glass-edge pointer-events-none"></div>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Project 2: AI Invoice Extractor -->
      <div class="star-border group relative bg-gray-800 rounded-2xl overflow-hidden border border-gray-700 hover:border-transparent transition-all duration-500 cursor-pointer w-full" data-modal="modal2">
        <!-- Project Image -->
        <div class="aspect-[4/5] bg-gray-800 relative overflow-hidden">
          <Image 
            src={invoiceExtractor}
            alt={t.caseStudies.project2Alt}
            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-110 group-hover:blur-sm"
            quality={90}
            format="webp"
          />
          <!-- Hover Overlay -->
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-between p-4 sm:p-6">
            <div class="w-full flex justify-center">
              <h3 class="text-xl sm:text-2xl font-bold text-white mb-2 break-words text-center">{t.caseStudies.project2Title}</h3>
            </div>
            <div class="flex items-end justify-between w-full">
              <!-- Logo bottom left -->
              <div class="flex items-center flex-shrink-0">
                <svg class="w-8 sm:w-10 h-8 sm:h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3"></path>
                </svg>
              </div>
              <!-- Button bottom right -->
              <button class="liquid-glass-btn relative px-4 sm:px-6 py-2 rounded-xl font-semibold transition-all duration-300 ml-auto text-sm sm:text-base whitespace-nowrap overflow-hidden group">
                <!-- Liquid glass background overlay -->
                <div class="absolute inset-0 rounded-xl glass-overlay opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                
                <!-- Liquid light reflection -->
                <div class="absolute top-0 left-[-100%] w-full h-full glass-reflection transform -skew-x-12 group-hover:left-[100%] transition-all duration-600 ease-out"></div>
                
                <!-- Button content -->
                <span class="relative z-10 text-white font-medium">{t.caseStudies.seeMore}</span>
                
                <!-- Glass edge highlight -->
                <div class="absolute inset-0 rounded-xl glass-edge pointer-events-none"></div>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Project 3: Residential Access Control -->
      <div class="star-border group relative bg-gray-800 rounded-2xl overflow-hidden border border-gray-700 hover:border-transparent transition-all duration-500 cursor-pointer w-full" data-modal="modal3">
        <!-- Project Image -->
        <div class="aspect-[4/5] bg-gray-800 relative overflow-hidden">
          <Image 
            src={residentialManagement}
            alt={t.caseStudies.project3Alt}
            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-110 group-hover:blur-sm"
            quality={90}
            format="webp"
          />
          <!-- Hover Overlay -->
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-between p-4 sm:p-6">
            <div class="w-full flex justify-center">
              <h3 class="text-xl sm:text-2xl font-bold text-white mb-2 break-words text-center">{t.caseStudies.project3Title}</h3>
            </div>
            <div class="flex items-end justify-between w-full">
              <!-- Logo bottom left -->
              <div class="flex items-center flex-shrink-0">
                <svg class="w-8 sm:w-10 h-8 sm:h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <!-- Button bottom right -->
              <button class="liquid-glass-btn relative px-4 sm:px-6 py-2 rounded-xl font-semibold transition-all duration-300 ml-auto text-sm sm:text-base whitespace-nowrap overflow-hidden group">
                <!-- Liquid glass background overlay -->
                <div class="absolute inset-0 rounded-xl glass-overlay opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                
                <!-- Liquid light reflection -->
                <div class="absolute top-0 left-[-100%] w-full h-full glass-reflection transform -skew-x-12 group-hover:left-[100%] transition-all duration-600 ease-out"></div>
                
                <!-- Button content -->
                <span class="relative z-10 text-white font-medium">{t.caseStudies.seeMore}</span>
                
                <!-- Glass edge highlight -->
                <div class="absolute inset-0 rounded-xl glass-edge pointer-events-none"></div>
              </button>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>

  <!-- Modal Backdrop -->
  <div id="modalBackdrop" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300 w-full h-full"></div>

  <!-- Modal 1: AI Files Management -->
  <div id="modal1" class="fixed inset-x-2 sm:inset-x-4 lg:inset-x-0 bottom-0 bg-background-primary border border-white/20 rounded-t-2xl sm:rounded-t-3xl z-50 transform translate-y-full transition-transform duration-500 ease-out max-w-4xl mx-auto w-full max-h-[90vh] overflow-y-auto">
    <div class="p-3 sm:p-6 lg:p-8 w-full">
      <!-- Modal Header -->
      <div class="flex justify-between items-start mb-3 sm:mb-6">
        <h3 class="text-lg sm:text-2xl lg:text-3xl font-bold text-white break-words flex-1 pr-3">{t.caseStudies.project1Title}</h3>
        <button class="close-modal text-gray-400 hover:text-white text-xl sm:text-2xl font-light flex-shrink-0">×</button>
      </div>
      
      <!-- Modal Content -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 sm:gap-6 lg:gap-8 mb-3 sm:mb-6 lg:mb-8">
        <div class="w-full order-1">
          <div class="aspect-[16/9] sm:aspect-[4/3] bg-background-secondary border border-white/10 rounded-lg sm:rounded-xl overflow-hidden mb-3 sm:mb-4 w-full">
            <Image 
              src={aiFileSystem}
              alt={t.caseStudies.project1ModalAlt}
              class="w-full h-full object-cover"
              quality={90}
              format="webp"
            />
          </div>
        </div>
        <div class="w-full order-2">
          <p class="text-gray-300 text-sm sm:text-base lg:text-lg leading-relaxed mb-3 sm:mb-4 lg:mb-6 break-words">
            {t.caseStudies.project1Desc}
          </p>
          <div class="space-y-2 sm:space-y-3">
            <div class="flex items-start space-x-2 sm:space-x-3">
              <div class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-primary-400 rounded-full mt-1.5 sm:mt-2 flex-shrink-0"></div>
              <span class="text-gray-200 text-xs sm:text-sm lg:text-base break-words flex-1">{t.caseStudies.project1Feature1}</span>
            </div>
            <div class="flex items-start space-x-2 sm:space-x-3">
              <div class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-primary-400 rounded-full mt-1.5 sm:mt-2 flex-shrink-0"></div>
              <span class="text-gray-200 text-xs sm:text-sm lg:text-base break-words flex-1">{t.caseStudies.project1Feature2}</span>
            </div>
            <div class="flex items-start space-x-2 sm:space-x-3">
              <div class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-primary-400 rounded-full mt-1.5 sm:mt-2 flex-shrink-0"></div>
              <span class="text-gray-200 text-xs sm:text-sm lg:text-base break-words flex-1">{t.caseStudies.project1Feature3}</span>
            </div>
          </div>
        </div>
      </div>
      
