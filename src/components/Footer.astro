---
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);
const base = lang === "es" ? "/es" : "";
---

<footer class="bg-gray-900 border-t border-gray-800 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24 relative z-10">
    
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-12">
      
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <div class="flex items-center mb-6">
          <span class="text-2xl font-bold text-white">ORION</span>
          <div class="w-2 h-2 bg-primary-400 rounded-full ml-2"></div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          {t.footer.description}
        </p>
        <!-- <div class="flex space-x-4">
          <a href="#" class="text-gray-400 hover:text-white transition-colors duration-300">
            <span class="sr-only">LinkedIn</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
          <a href="#" class="text-gray-400 hover:text-white transition-colors duration-300">
            <span class="sr-only">Twitter</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="#" class="text-gray-400 hover:text-white transition-colors duration-300">
            <span class="sr-only">GitHub</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.237 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div> -->
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-6">{t.footer.quickLinks}</h4>
        <ul class="space-y-4">
          <li><a href="#process" class="text-gray-400 hover:text-white transition-colors duration-300 text-sm">{t.footer.ourProcess}</a></li>
          <li><a href="#case-studies" class="text-gray-400 hover:text-white transition-colors duration-300 text-sm">{t.footer.caseStudies}</a></li>
          <li><a href="#pricing" class="text-gray-400 hover:text-white transition-colors duration-300 text-sm">{t.footer.pricing}</a></li>
          <li><a href="#testimonials" class="text-gray-400 hover:text-white transition-colors duration-300 text-sm">{t.footer.clientStories}</a></li>
        </ul>
      </div>
      
      <!-- Contact Info -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-6">{t.footer.contact}</h4>
        <ul class="space-y-4">
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-400 mt-1 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:hello@orion.dev" class="text-gray-400 hover:text-white transition-colors duration-300 text-sm">hello@orion.dev</a>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-400 mt-1 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+1234567890" class="text-gray-400 hover:text-white transition-colors duration-300 text-sm">+1 (234) 567-8900</a>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary-400 mt-1 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-gray-400 text-sm">{t.footer.responseTime}</span>
          </li>
        </ul>
      </div>
      
      <!-- Newsletter -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-6">{t.footer.stayUpdated}</h4>
        <p class="text-gray-400 text-sm mb-4">{t.footer.newsletterText}</p>
        <form class="space-y-2">
          <div class="flex">
            <input type="email" placeholder={t.footer.emailPlaceholder} class="bg-gray-800 text-white px-4 py-2 rounded-l-lg w-full text-sm focus:outline-none focus:ring-2 focus:ring-primary-400">
            <button type="submit" class="bg-primary-400 hover:bg-primary-500 text-black px-4 py-2 rounded-r-lg text-sm font-semibold transition-colors duration-300">
              {t.footer.subscribe}
            </button>
          </div>
          <p class="text-xs text-gray-500">{t.footer.privacyText}</p>
        </form>
      </div>
      
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 pt-8 mt-12">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <div class="flex items-center space-x-4">
          <span class="text-sm text-gray-400">{t.footer.copyright}</span>
          <span class="text-gray-700">|</span>
          <a href={`${base}/privacy`} class="text-sm text-gray-400 hover:text-white transition-colors duration-300">{t.footer.privacyPolicy}</a>
          <span class="text-gray-700">|</span>
          <a href={`${base}/terms`} class="text-sm text-gray-400 hover:text-white transition-colors duration-300">{t.footer.termsOfService}</a>
        </div>
        <div class="flex items-center space-x-6">
          <div class="flex items-center">
            <div class="w-2 h-2 bg-primary-400 rounded-full mr-2"></div>
            <span class="text-sm text-gray-400">{t.footer.delivery}</span>
          </div>
          <div class="flex items-center">
            <div class="w-2 h-2 bg-blue-500 rounded-full mr-2"></div>
            <span class="text-sm text-gray-400">{t.footer.startupFriendly}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Enhanced Background Effects -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-400/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-primary-400/3 to-blue-500/3 rounded-full blur-3xl"></div>
  </div>
</footer>

<style>
  @keyframes scaleX {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
  
  /* Subtle hover effects */
  .hover-lift {
    transition: transform 0.2s ease;
  }
  
  .hover-lift:hover {
    transform: translateY(-2px);
  }
</style> 