      <!-- Product Links -->
      <div>
        <h3 class="text-text-primary font-semibold mb-4">Product</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Features</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Pricing</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Integrations</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">API</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Security</a></li>
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="text-text-primary font-semibold mb-4">Company</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">About</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Blog</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Careers</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Press</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Partners</a></li>
        </ul>
      </div>

      <!-- Support Links -->
      <div>
        <h3 class="text-text-primary font-semibold mb-4">Support</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Help Center</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Documentation</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Contact</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Status</a></li>
          <li><a href="#" class="text-text-secondary hover:text-text-primary transition-colors duration-200">Community</a></li>
        </ul>
      </div>
    </div>

    <!-- Trust Indicators -->
    <div class="border-t border-border-primary mt-12 pt-8 mb-8">
      <div class="flex flex-col md:flex-row items-center justify-center space-y-4 md:space-y-0 md:space-x-12">
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-secondary-main rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <span class="text-text-secondary font-medium">SOC 2 Certified</span>
        </div>
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-primary-main rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <span class="text-text-secondary font-medium">GDPR Compliant</span>
        </div>
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-gradient-accent rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
            </svg>
          </div>
          <span class="text-text-secondary font-medium">Industry Leader</span>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-border-primary pt-8 flex flex-col md:flex-row justify-between items-center">
      <div class="text-text-muted text-sm mb-4 md:mb-0">
        © 2024 Orion. All rights reserved.
      </div>
      <div class="flex space-x-6 text-sm">
        <a href="#" class="text-text-muted hover:text-text-primary transition-colors duration-200">Privacy Policy</a>
        <a href="#" class="text-text-muted hover:text-text-primary transition-colors duration-200">Terms of Service</a>
        <a href="#" class="text-text-muted hover:text-text-primary transition-colors duration-200">Cookie Policy</a>
      </div>
    </div>
