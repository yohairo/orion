// Testimonials Section component
---

<style>
  @keyframes scaleX {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  /* Star Border Effect */
  .star-border {
    position: relative;
    border: 1px solid transparent;
    background: linear-gradient(#27272a, #27272a) padding-box,
                linear-gradient(90deg, 
                  transparent, 
                  rgba(255, 164, 0, var(--glow-opacity, 0)), 
                  transparent) border-box;
    background-size: 100% 100%, 400% 100%;
    animation: star-sweep 30s ease-in-out infinite;
    transition: all 0.3s ease;
  }
  
  .star-border:hover {
    box-shadow: 0 0 20px rgba(255, 164, 0, 0.4);
  }
  
  @keyframes star-sweep {
    0% {
      background-position: 0% 0%, -400% 0%;
      --glow-opacity: 0;
    }
    20% {
      --glow-opacity: 0.8;
    }
    40% {
      background-position: 0% 0%, 200% 0%;
      --glow-opacity: 1;
    }
    60% {
      background-position: 0% 0%, 400% 0%;
      --glow-opacity: 0.8;
    }
    75% {
      --glow-opacity: 0;
    }
    100% {
      background-position: 0% 0%, -400% 0%;
      --glow-opacity: 0;
    }
  }

  /* Background Styles */
  .testimonials-bg {
    background: linear-gradient(135deg, #1a1d21 0%, #2a2d32 25%, #232528 50%, #1e2124 75%, #1a1d21 100%);
    position: relative;
  }
  
  .testimonials-bg::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 20%, rgba(255, 164, 0, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(234, 246, 255, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(255, 164, 0, 0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Floating Orbs */
  .floating-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.4;
    animation: float 20s ease-in-out infinite;
  }
  
  .orb-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 164, 0, 0.15) 0%, rgba(255, 164, 0, 0.05) 40%, transparent 70%);
    top: 10%;
    left: -5%;
    animation-delay: 0s;
  }
  
  .orb-2 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(234, 246, 255, 0.1) 0%, rgba(234, 246, 255, 0.03) 40%, transparent 70%);
    top: 60%;
    right: -3%;
    animation-delay: -7s;
  }
  
  .orb-3 {
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(255, 164, 0, 0.08) 0%, rgba(255, 164, 0, 0.02) 40%, transparent 70%);
    top: 30%;
    left: 70%;
    animation-delay: -14s;
  }

  /* Grid Pattern */
  .grid-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      linear-gradient(rgba(255, 164, 0, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 164, 0, 0.02) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.3;
    pointer-events: none;
  }

  /* Stars */
  .star {
    position: absolute;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    animation: twinkle 4s ease-in-out infinite;
  }
  
  .star-small {
    width: 1px;
    height: 1px;
    animation-duration: 3s;
  }
  
  .star-medium {
    width: 2px;
    height: 2px;
    animation-duration: 5s;
  }
  
  .star-large {
    width: 3px;
    height: 3px;
    animation-duration: 6s;
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.5);
  }
  
  .star-amber {
    background: rgba(255, 164, 0, 0.6);
    box-shadow: 0 0 4px rgba(255, 164, 0, 0.3);
  }
  
  .star-blue {
    background: rgba(234, 246, 255, 0.7);
    box-shadow: 0 0 4px rgba(234, 246, 255, 0.2);
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px) translateX(0px) scale(1);
    }
    25% {
      transform: translateY(-20px) translateX(10px) scale(1.1);
    }
    50% {
      transform: translateY(-10px) translateX(-15px) scale(0.9);
    }
    75% {
      transform: translateY(-30px) translateX(5px) scale(1.05);
    }
  }

  @keyframes twinkle {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  .star:nth-child(2n) { animation-delay: -1s; }
  .star:nth-child(3n) { animation-delay: -2s; }
  .star:nth-child(4n) { animation-delay: -3s; }
  .star:nth-child(5n) { animation-delay: -0.5s; }
  .star:nth-child(6n) { animation-delay: -1.5s; }
</style>

