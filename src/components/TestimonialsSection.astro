---
// Testimonials Section component
---

<section id="testimonials" class="py-20 lg:py-32 bg-background-secondary relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-6">
        What Our Customers
        <span class="bg-gradient-primary bg-clip-text text-transparent">Are Saying</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed">
        Join thousands of satisfied customers who have transformed their businesses with Orion.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      
      <!-- Testimonial 1 -->
      <div class="bg-background-card/80 backdrop-blur-xl border border-border-primary rounded-2xl p-8 hover:border-border-accent transition-all duration-300 hover:transform hover:-translate-y-2">
        <!-- Rating -->
        <div class="flex items-center mb-4">
          <div class="flex space-x-1">
