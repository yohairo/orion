---
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);

const cards = [
  {
    key: "saas",
    featured: false,
    cardClass: "bg-gray-900/50 border border-gray-700 rounded-xl p-6 sm:p-8 hover:border-gray-600 transition-all duration-300",
    badgeClass: "",
    ctaClass: "w-full bg-primary-400 hover:bg-coral-400 text-black px-8 py-2 sm:py-3 rounded-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-400/25 text-sm sm:text-base",
    checkColor: "text-primary-400"
  },
  {
    key: "automations",
    featured: true,
    cardClass: "bg-gray-900/50 border-2 border-primary-400 rounded-xl p-6 sm:p-8 relative lg:scale-105",
    badgeClass: "bg-primary-400 text-black",
    ctaClass: "w-full bg-primary-400 hover:bg-coral-400 text-black px-8 py-2 sm:py-3 rounded-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-400/25 text-sm sm:text-base",
    checkColor: "text-primary-400"
  },
  {
    key: "agents",
    featured: false,
    cardClass: "bg-gray-900/50 border border-gray-700 rounded-xl p-6 sm:p-8 hover:border-gray-600 transition-all duration-300",
    badgeClass: "",
    ctaClass: "w-full bg-primary-400 hover:bg-coral-400 text-black px-8 py-2 sm:py-3 rounded-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-400/25 text-sm sm:text-base",
    checkColor: "text-blue-500"
  }
] as const;
---

<section id="pricing" class="min-h-screen flex items-center py-16 sm:py-20 lg:py-24 bg-gray-800 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 sm:mb-6 px-2 break-words">
        {t.pricing.headline}
        <div class="relative inline-block">
          <span class="text-white font-bold relative">
            <span class="relative z-10">{t.pricing.headlineHighlight}</span>
            <div 
              class="absolute bottom-[6px] left-0 w-full h-[0.15em] bg-primary-400 transform origin-left z-0"
              style="animation: scaleX 0.4s ease-out 1.4s forwards;"
            ></div>
          </span>
        </div>
      </h2>
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-6 sm:mb-8 px-2 break-words">
        {t.pricing.description}
      </p>
    </div>

    <!-- Service Packages -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-12 sm:mb-16 w-full">
      {cards.map((card) => {
        const data = t.pricing[card.key] as { title: string; subtitle: string; priceRange: string; priceNote: string; popular: string; cta: string; features: string[] };
        return (
          <div class={card.cardClass}>
            <!-- Popular Badge -->
            {card.featured && data.popular ? (
              <div class="absolute -top-3 sm:-top-4 left-1/2 transform -translate-x-1/2 z-10">
                <div class={`${card.badgeClass} px-4 sm:px-6 py-1 sm:py-2 rounded-full text-xs sm:text-sm font-semibold whitespace-nowrap`}>
                  {data.popular}
                </div>
              </div>
            ) : null}

            <div class={`text-center mb-6 sm:mb-8 ${card.featured ? 'pt-4 sm:pt-0' : ''}`}>
              <h3 class="text-lg sm:text-xl font-bold text-white mb-2 break-words">{data.title}</h3>
              <p class="text-gray-400 mb-4 sm:mb-6 text-sm sm:text-base break-words">{data.subtitle}</p>
              <div class="mb-2 sm:mb-3">
                <span class="text-2xl sm:text-3xl font-bold text-white">{data.priceRange}</span>
              </div>
              <div class="text-xs sm:text-sm text-gray-500 mb-4 sm:mb-6 break-words">{data.priceNote}</div>
              <a href="#contact" class={card.ctaClass}>
                {data.cta}
              </a>
            </div>

            <!-- Features -->
            <div class="space-y-3 sm:space-y-4 w-full">
              {data.features.map((feature: string) => (
                <div class="flex items-start space-x-3">
                  <svg class={`w-4 h-4 ${card.checkColor} flex-shrink-0 mt-0.5`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-300 text-xs sm:text-sm break-words flex-1">{feature}</span>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center w-full">
      <h3 class="text-xl sm:text-2xl font-bold text-white mb-3 sm:mb-4 px-2 break-words">{t.pricing.bottomTitle}</h3>
      <p class="text-gray-400 mb-6 sm:mb-8 max-w-2xl mx-auto text-sm sm:text-base px-2 break-words">
        {t.pricing.bottomText}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center space-y-3 sm:space-y-0 sm:space-x-4 w-full px-2">
        <a href="#contact" class="bg-primary-400 hover:bg-coral-400 text-black px-6 sm:px-8 py-3 sm:py-4 rounded-lg text-base sm:text-lg font-semibold transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-400/25 w-full sm:w-auto max-w-xs break-words inline-block text-center">
          {t.pricing.bottomCta1}
        </a>
        <a href="#contact" class="border border-gray-700 hover:border-gray-600 text-gray-300 hover:text-white px-6 sm:px-8 py-3 sm:py-4 rounded-lg text-base sm:text-lg font-semibold transition-all duration-300 w-full sm:w-auto max-w-xs break-words inline-block text-center">
          {t.pricing.bottomCta2}
        </a>
      </div>
    </div>
  </div>

  <!-- Subtle Background Effects -->
  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary-400/5 rounded-full blur-3xl pointer-events-none"></div>
</section>

<style>
  @keyframes scaleX {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
</style>
