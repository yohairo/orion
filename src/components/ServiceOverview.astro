---
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);

const blocks = [
  {
    key: "automations",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
    </svg>`,
    gradient: "from-amber-600/40 via-primary-500/30 to-amber-600/40",
    textAccent: "text-primary-400",
    bgAccent: "bg-primary-400/20",
    borderAccent: "border-primary-400/30",
    bgAccentHover: "hover:bg-primary-400/20",
    blurBg: "bg-primary-400/10",
    textIcon: "text-primary-400/90"
  },
  {
    key: "agents",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>`,
    gradient: "from-blue-700/40 via-blue-600/30 to-blue-700/40",
    textAccent: "text-blue-400",
    bgAccent: "bg-blue-500/20",
    borderAccent: "border-blue-500/30",
    bgAccentHover: "hover:bg-blue-500/20",
    blurBg: "bg-blue-500/10",
    textIcon: "text-blue-400/90"
  },
  {
    key: "saas",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
    </svg>`,
    gradient: "from-violet-600/40 via-violet-500/30 to-violet-600/40",
    textAccent: "text-violet-400",
    bgAccent: "bg-violet-500/20",
    borderAccent: "border-violet-500/30",
    bgAccentHover: "hover:bg-violet-500/20",
    blurBg: "bg-violet-500/10",
    textIcon: "text-violet-400/90"
  }
] as const;


---

<section id="services" class="min-h-screen flex items-center py-16 sm:py-20 lg:py-24 bg-gray-800 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">

    <!-- Section Header -->
    <div class="text-center mb-16 sm:mb-20 lg:mb-24 w-full">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4 sm:mb-6 break-words">
        {t.services.headline}
      </h2>
      <p class="text-sm sm:text-base text-gray-400 max-w-2xl mx-auto leading-relaxed break-words">
        {t.services.subtitle}
      </p>
    </div>

    <!-- Service Blocks -->
    {
      blocks.map((block, i) => {
        const data = t.services[block.key];
        const isReversed = i % 2 !== 0;
        return (
          <div class="mb-20 sm:mb-24 lg:mb-28 last:mb-0 w-full">
            <div class={`flex flex-col ${isReversed ? 'lg:flex-row-reverse' : 'lg:flex-row'} items-center gap-8 sm:gap-10 lg:gap-14 w-full`}>

              <!-- Visual Placeholder -->
              <div class="w-full lg:w-1/2 flex-shrink-0">
                <div class={`relative w-full aspect-[4/3] rounded-2xl sm:rounded-3xl bg-gradient-to-br ${block.gradient} border border-white/10 overflow-hidden flex items-center justify-center`}>
                  <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
                  <div class={`relative z-10 ${block.textIcon}`} set:html={block.icon} />
                  <div class={`absolute top-6 right-6 w-24 h-24 ${block.blurBg} rounded-full blur-2xl`}></div>
                  <div class={`absolute bottom-6 left-6 w-16 h-16 ${block.blurBg} rounded-full blur-xl`}></div>
                </div>
              </div>

              <!-- Content -->
              <div class="w-full lg:w-1/2">
                <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-white mb-3 sm:mb-4 break-words">
                  {data.title}
                </h3>
                <p class="text-sm sm:text-base text-gray-400 mb-6 sm:mb-8 leading-relaxed break-words">
                  {data.description}
                </p>

                <!-- Features -->
                <ul class="space-y-3 sm:space-y-4 mb-8 sm:mb-10 w-full">
                  {
                    data.features.map((feature: string) => (
                      <li class="flex items-start gap-3">
                        <span class={`w-5 h-5 rounded-full ${block.bgAccent} flex items-center justify-center flex-shrink-0 mt-0.5`}>
                          <svg class={`w-3 h-3 ${block.textAccent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                          </svg>
                        </span>
                        <span class="text-sm sm:text-base text-gray-300 break-words">{feature}</span>
                      </li>
                    ))
                  }
                </ul>

                <!-- CTA -->
                <a
                  href="#contact"
                  class={`inline-flex items-center gap-2 px-6 py-3 ${block.bgAccent} ${block.borderAccent} ${block.bgAccentHover} ${block.textAccent} rounded-xl text-sm font-medium transition-colors duration-200`}
                >
                  {data.cta}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </a>
              </div>

            </div>
          </div>
        );
      })
    }

  </div>

  <!-- Background Effects -->
  <div class="absolute top-1/4 right-1/4 w-64 h-64 bg-primary-400/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/4 left-1/4 w-48 h-48 bg-blue-500/5 rounded-full blur-3xl pointer-events-none"></div>
</section>
