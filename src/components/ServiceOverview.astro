---
import { getTranslations } from '../i18n';
const { lang = "en" } = Astro.props;
const t = getTranslations(lang);
---

<section id="services" class="min-h-screen flex items-center py-16 sm:py-20 lg:py-24 bg-gray-800 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    
    <!-- Section Header -->
    <div class="text-center mb-16 sm:mb-20 lg:mb-24 w-full">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4 sm:mb-6 break-words">
        {t.services.headline1}
        <div class="relative inline-block">
          <span class="text-white font-bold relative">
            <span class="relative z-10">{t.services.headlineHighlight}</span>
            <div 
              class="absolute bottom-[6px] left-0 w-full h-[0.15em] bg-primary-400 transform origin-left z-0"
              style="animation: scaleX 0.4s ease-out 1.4s forwards;"
            ></div>
          </span>
        </div>
      </h2>
      <p class="text-sm sm:text-base text-gray-400 max-w-2xl mx-auto leading-relaxed break-words">
        {t.services.description}
      </p>
    </div>

    <!-- Main Service Card -->
    <div class="relative mb-12 sm:mb-16 w-full">
      <!-- Gradient border effect -->
      <div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 via-primary-400/20 to-blue-500/20 rounded-2xl sm:rounded-3xl blur-sm"></div>
      
      <div class="relative bg-gradient-to-br from-gray-900/90 via-gray-700/90 to-gray-900/90 backdrop-blur-xl rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 border border-gray-700/50 shadow-2xl shadow-blue-500/5 w-full">
        <!-- Decorative elements -->
        <div class="absolute top-4 sm:top-6 right-4 sm:right-6 w-16 sm:w-20 h-16 sm:h-20 bg-gradient-to-br from-blue-500/10 to-primary-400/10 rounded-full blur-2xl"></div>
        <div class="absolute bottom-4 sm:bottom-6 left-4 sm:left-6 w-12 sm:w-16 h-12 sm:h-16 bg-gradient-to-tr from-primary-400/10 to-blue-500/10 rounded-full blur-2xl"></div>
        
        <!-- Content -->
        <div class="relative z-10 text-center w-full">
          <div class="inline-flex items-center px-3 sm:px-4 py-1 sm:py-2 bg-primary-400/10 border border-primary-400/20 rounded-full text-primary-400 text-xs sm:text-sm font-medium mb-4 sm:mb-6">
            <span class="w-2 h-2 bg-primary-400 rounded-full mr-2 flex-shrink-0"></span>
            {t.services.badge}
          </div>
          
          <h3 class="text-lg sm:text-xl lg:text-2xl font-bold text-white mb-3 sm:mb-4 break-words">
            {t.services.cardTitle}
          </h3>
          
          <p class="text-xs sm:text-sm text-gray-400 mb-4 sm:mb-6 max-w-xl mx-auto leading-relaxed break-words">
            {t.services.cardText}
          </p>
          
          <!-- Key Features Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 w-full">
            <div class="text-center p-3 rounded-lg bg-gray-800/30 border border-gray-700/50 w-full">
              <div class="w-8 h-8 bg-primary-400/20 rounded-lg flex items-center justify-center mx-auto mb-2 flex-shrink-0">
                <svg class="w-4 h-4 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h4 class="font-semibold text-white text-xs mb-1 break-words">{t.services.pill1Title}</h4>
              <p class="text-xs text-gray-400 break-words">{t.services.pill1Text}</p>
            </div>
            
            <div class="text-center p-3 rounded-lg bg-gray-800/30 border border-gray-700/50 w-full">
              <div class="w-8 h-8 bg-primary-500/20 rounded-lg flex items-center justify-center mx-auto mb-2 flex-shrink-0">
                <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
              </div>
              <h4 class="font-semibold text-white text-xs mb-1 break-words">{t.services.pill2Title}</h4>
              <p class="text-xs text-gray-400 break-words">{t.services.pill2Text}</p>
            </div>
            
            <div class="text-center p-3 rounded-lg bg-gray-800/30 border border-gray-700/50 w-full">
              <div class="w-8 h-8 bg-coral-400/20 rounded-lg flex items-center justify-center mx-auto mb-2 flex-shrink-0">
                <svg class="w-4 h-4 text-coral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h4 class="font-semibold text-white text-xs mb-1 break-words">{t.services.pill3Title}</h4>
              <p class="text-xs text-gray-400 break-words">{t.services.pill3Text}</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Service Details -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 w-full">
      
      <!-- What We Build -->
      <div class="w-full">
        <h3 class="text-lg sm:text-xl font-bold text-white mb-4 sm:mb-6 break-words">{t.services.whatWeBuild}</h3>
        <div class="space-y-3 sm:space-y-4 w-full">
          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 bg-primary-400/20 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
              </svg>
            </div>
            <div class="flex-1">
              <h4 class="font-semibold text-white mb-1 text-xs sm:text-sm break-words">{t.services.item1Title}</h4>
              <p class="text-xs text-gray-400 leading-relaxed break-words">
                {t.services.item1Text}
              </p>
            </div>
          </div>
          
          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 bg-primary-500/20 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="flex-1">
              <h4 class="font-semibold text-white mb-1 text-xs sm:text-sm break-words">{t.services.item2Title}</h4>
              <p class="text-xs text-gray-400 leading-relaxed break-words">
                {t.services.item2Text}
              </p>
            </div>
          </div>
          
          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 bg-coral-400/20 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-coral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div class="flex-1">
              <h4 class="font-semibold text-white mb-1 text-xs sm:text-sm break-words">{t.services.item3Title}</h4>
              <p class="text-xs text-gray-400 leading-relaxed break-words">
                {t.services.item3Text}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- How We're Different -->
      <div class="w-full">
        <h3 class="text-lg sm:text-xl font-bold text-white mb-4 sm:mb-6 break-words">{t.services.howDifferent}</h3>
        <div class="space-y-3 w-full">
          <div class="p-3 bg-gray-800/50 border border-gray-700/50 rounded-lg w-full">
            <div class="flex items-center mb-2">
              <div class="w-2 h-2 bg-primary-400 rounded-full mr-2 flex-shrink-0"></div>
              <h4 class="font-semibold text-white text-xs break-words flex-1">{t.services.diff1Title}</h4>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed ml-4 break-words">
              {t.services.diff1Text}
            </p>
          </div>
          
          <div class="p-3 bg-gray-800/50 border border-gray-700/50 rounded-lg w-full">
            <div class="flex items-center mb-2">
              <div class="w-2 h-2 bg-blue-500 rounded-full mr-2 flex-shrink-0"></div>
              <h4 class="font-semibold text-white text-xs break-words flex-1">{t.services.diff2Title}</h4>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed ml-4 break-words">
              {t.services.diff2Text}
            </p>
          </div>
          
          <div class="p-3 bg-gray-800/50 border border-gray-700/50 rounded-lg w-full">
            <div class="flex items-center mb-2">
              <div class="w-2 h-2 bg-coral-400 rounded-full mr-2 flex-shrink-0"></div>
              <h4 class="font-semibold text-white text-xs break-words flex-1">{t.services.diff3Title}</h4>
            </div>
            <p class="text-xs text-gray-400 leading-relaxed ml-4 break-words">
              {t.services.diff3Text}
            </p>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Background Effects -->
  <div class="absolute top-1/4 right-1/4 w-64 h-64 bg-primary-400/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/4 left-1/4 w-48 h-48 bg-blue-500/5 rounded-full blur-3xl pointer-events-none"></div>
</section>

<style>
  @keyframes scaleX {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
  
  @keyframes shine {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
  
  .animate-shine {
    animation: shine 3s ease-in-out infinite;
    animation-delay: 1s;
  }
</style> 