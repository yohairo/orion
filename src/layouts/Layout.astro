---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "Scale Your Business Without Limits - Orion Intelligence Platform", lang = "en" } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Optimized font loading with resource hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    
    <!-- Lora (h1) + Fraunces (h2) + Inter (body) -->
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Performance and SEO optimizations -->
    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#232528">
    <meta name="robots" content="index, follow">
    <meta name="author" content="Orion Intelligence">
    
    <!-- Critical CSS inline for above-the-fold content -->
    <style>
      /* Critical styles - above the fold */
      html {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        overflow-x: hidden;
        max-width: 100vw;
        width: 100%;
        scroll-behavior: smooth;
      }
      
      body {
        overflow-x: hidden;
        max-width: 100vw;
        width: 100%;
        margin: 0;
        padding: 0;
        background: #232528;
        color: white;
        font-family: inherit;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      /* Performance optimizations */
      * {
        box-sizing: border-box;
      }
      
      /* GPU acceleration for animations */
      [data-animate] {
        will-change: transform, opacity;
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
      }
      
      /* Optimize expensive properties */
      .blur-effect {
        will-change: filter;
        contain: layout style paint;
      }
      
      /* Reduce layout shifts */
      img, video, iframe {
        max-width: 100%;
        height: auto;
        display: block;
      }
      
      /* Ensure containers respect viewport width */
      .container, section, div, main, article, header, footer {
        max-width: 100%;
      }
      
      /* Prevent text from breaking layout */
      p, h1, h2, h3, h4, h5, h6, span, a, button {
        word-wrap: break-word;
        overflow-wrap: break-word;
        hyphens: auto;
      }
      
      /* Ensure grids don't overflow */
      .grid {
        width: 100%;
        max-width: 100%;
      }
      
      /* Fix for absolute positioned elements */
      .absolute {
        max-width: 100vw;
      }

      /*
       * Safety net: the hero's entrance animations start from opacity:0 (baked
       * into the SSR HTML by framer-motion). If scripting is unavailable, those
       * elements would never animate in and the hero would look blank. Force
       * them visible so the hero always renders without JS.
       */
      @media (scripting: none) {
        #hero [style*="opacity"] {
          opacity: 1 !important;
          transform: none !important;
        }
      }
    </style>
    <noscript>
      <style>
        #hero [style*="opacity"] {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body class="bg-background-primary text-white font-sans antialiased overflow-x-hidden w-full">
    <!-- Background Effects -->
    <div class="fixed inset-0 bg-gradient-radial pointer-events-none"></div>
    <div class="fixed inset-0 bg-gradient-mesh pointer-events-none opacity-30"></div>
    
    <!-- Main Content -->
    <div class="w-full max-w-full overflow-x-hidden">
      <main class="relative z-10">
        <slot />
      </main>
    </div>

    <style is:global>
      /* Non-critical CSS - loaded after critical path */
      
      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 4px;
      }
      
      ::-webkit-scrollbar-track {
        background: #2a2d30;
      }
      
      ::-webkit-scrollbar-thumb {
        background: #FFA400;
        border-radius: 2px;
      }
      
      ::-webkit-scrollbar-thumb:hover {
        background: #f59e0b;
      }

      /* Optimized transitions - only for interactive elements */
      button, a, [role="button"] {
        transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease, opacity 0.15s ease;
      }

      /* Reduce motion for accessibility and performance */
      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        
        /* Disable expensive animations on low-power devices */
        [data-animate] {
          animation: none !important;
          transform: none !important;
        }
      }
      
      /* Performance optimization for low-end devices */
      @media (max-width: 768px) {
        .blur-effect {
          filter: none !important;
        }
        
        [data-animate] {
          will-change: auto;
        }
      }
    </style>
    
    <!-- Load non-critical JavaScript after page load -->
    <script>
      // Intersection Observer for lazy loading animations
      if ('IntersectionObserver' in window) {
        const animationObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-in');
            }
          });
        }, { threshold: 0.1 });
        
        // Observe elements when DOM is ready
        document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('[data-animate]').forEach((el) => {
            animationObserver.observe(el);
          });
        });
      }
    </script>
  </body>
</html> 